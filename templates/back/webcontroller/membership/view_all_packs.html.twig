{% extends 'base.html.twig' %}
{% block title %}Nos packs - RACS Health Global{% endblock %}
{% block page_title %}Nos packs de souscriptions{% endblock %}
{% block nav_packs %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="-m-5 sm:-m-6">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {% for membership in memberships %}
      {% if membership.membershipCost > 0 %}
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1 flex flex-col">
        {# Header #}
        <div class="bg-gradient-to-br from-jessica-600 to-jessica-500 p-6 text-white text-center">
          <h3 class="text-lg font-bold mb-1">{{ membership.name }}</h3>
          <div class="text-3xl font-black">{{ membership.membershipCost|number_format(0, ',', '.') }}</div>
          <div class="text-sm text-white/70">XAF</div>
        </div>

        {# Details #}
        <div class="p-5 flex-1">
          {% if membership.description %}
          <p class="text-sm text-gray-500 mb-4">{{ membership.description }}</p>
          {% endif %}
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm">
              <div class="w-8 h-8 rounded-lg bg-jessica-50 flex items-center justify-center flex-shrink-0">
                <i data-lucide="gift" class="w-4 h-4 text-jessica-500"></i>
              </div>
              <div>
                <span class="text-gray-500">Sponsoring :</span>
                <span class="font-semibold text-gray-800"> {{ membership.membershipBonusBinairePourcent|number_format(2, ',', ' ') }}%</span>
              </div>
            </li>
            <li class="flex items-center gap-3 text-sm">
              <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center flex-shrink-0">
                <i data-lucide="git-merge" class="w-4 h-4 text-blue-600"></i>
              </div>
              <div>
                <span class="text-gray-500">Binaire :</span>
                <span class="font-semibold text-gray-800"> {{ membership.membershipGroupeSV|number_format(2, ',', ' ') }} SV</span>
              </div>
            </li>
            <li class="flex items-center gap-3 text-sm">
              <div class="w-8 h-8 rounded-lg bg-accent-50 flex items-center justify-center flex-shrink-0">
                <i data-lucide="package" class="w-4 h-4 text-accent-500"></i>
              </div>
              <div>
                <span class="text-gray-500">Quote produit :</span>
                <span class="font-semibold text-gray-800"> {{ membership.membershipProductCote|number_format(2, ',', ' ') }}</span>
              </div>
            </li>
          </ul>
        </div>

        {# Actions #}
        <div class="p-5 border-t border-gray-100 space-y-2">
          {% if is_granted('add_member') %}
          <a href="{{ path('add_user_quickly', {'code': membership.code}) }}" class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
            <i data-lucide="user-plus" class="w-4 h-4"></i>
            Inscrire un distributeur
          </a>
          {% endif %}
          {% if membership.coefficent > app.user.membership.coefficent %}
          <button type="button" onclick="openModal('upgrade-{{ membership.id }}')" class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-accent-500 text-white text-sm font-semibold rounded-lg hover:bg-accent-600 transition-colors">
            <i data-lucide="arrow-up-circle" class="w-4 h-4"></i>
            Changer de pack
          </button>

          <div id="modal-upgrade-{{ membership.id }}" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
            <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full mx-4 p-6">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-accent-100 flex items-center justify-center">
                  <i data-lucide="arrow-up-circle" class="w-5 h-5 text-accent-600"></i>
                </div>
                <h3 class="text-lg font-bold text-gray-800">Changer de pack ?</h3>
              </div>
              <p class="text-sm text-gray-500 mb-6">Voulez-vous passer au pack <strong>{{ membership.name }}</strong> ?</p>
              <div class="flex gap-3 justify-end">
                <button onclick="closeModal('upgrade-{{ membership.id }}')" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Annuler</button>
                <form action="{{ path('membership_upgrade', {'code': membership.code}) }}" method="post" class="inline">
                  <input type="hidden" name="_method" value="POST">
                  <input type="hidden" name="_jtwc_membership_upgrade_token" value="{{ csrf_token('jtwc_membership-upgrade'~membership.id) }}">
                  <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-jessica-500 rounded-lg hover:bg-jessica-600 transition-colors">Confirmer</button>
                </form>
              </div>
            </div>
          </div>
          {% endif %}
        </div>
      </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% endblock %}
