{% extends 'base.html.twig' %}
{% block title %}Enregistrement d'un nouveau grade - RACS Health Global{% endblock %}
{% block page_title %}Enregistrement d'un nouveau grade{% endblock %}

{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">
  {% for type, messages in app.session.flashbag.all() %}
    {% for message in messages %}
      <div class="mx-5 px-4 py-3 rounded-lg text-sm font-medium {% if type == 'success' %}bg-green-50 text-green-700{% elseif type == 'danger' %}bg-red-50 text-red-700{% else %}bg-blue-50 text-blue-700{% endif %}">{{ message }}</div>
    {% endfor %}
  {% endfor %}

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    {{ form_start(form, {attr: {'novalidate': 'novalidate', 'id': 'form', 'class': 'divide-y divide-gray-100'}}) }}

    <div class="px-6 py-4 bg-gray-50">
      <div class="flex items-center gap-4 text-sm">
        <span class="step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-jessica-500 text-white font-semibold" id="step-ind-1"><span>1</span> Niveau associe au grade</span>
        <i data-lucide="chevron-right" class="w-4 h-4 text-gray-400"></i>
        <span class="step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gray-200 text-gray-600 font-medium" id="step-ind-2"><span>2</span> Bonus generationnel</span>
      </div>
    </div>

    <div id="step-1" class="p-6 space-y-5">
      <h3 class="text-base font-bold text-gray-800">Informations sur le niveau associe a un grade</h3>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.grade.vars.label }}</label>
          {{ form_widget(form.grade, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
          <div class="text-red-500 text-xs mt-1">{{ form_errors(form.grade) }}</div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.lvl.vars.label }}</label>
          {{ form_widget(form.lvl, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
          <div class="text-red-500 text-xs mt-1">{{ form_errors(form.lvl) }}</div>
        </div>
      </div>
      <div class="flex justify-end pt-2">
        <button type="button" onclick="showStep(2)" class="inline-flex items-center gap-2 px-4 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
          Suivant <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
      </div>
    </div>

    <div id="step-2" class="p-6 space-y-5 hidden">
      <h3 class="text-base font-bold text-gray-800">Bonus generationnel</h3>
      <div id="bg-fields-list" class="space-y-3" data-prototype="{{ form_widget(form.bgs.vars.prototype)|e }}"></div>
      <button type="button" class="add-bg inline-flex items-center gap-2 px-3 py-2 bg-blue-50 text-blue-600 text-sm font-medium rounded-lg hover:bg-blue-100 transition-colors" data-list-selector="#bg-fields-list">
        <i data-lucide="plus" class="w-4 h-4"></i> Ajouter un bonus
      </button>
      <div class="flex justify-between pt-2">
        <button type="button" onclick="showStep(1)" class="inline-flex items-center gap-2 px-4 py-2.5 bg-gray-100 text-gray-700 text-sm font-semibold rounded-lg hover:bg-gray-200 transition-colors">
          <i data-lucide="arrow-left" class="w-4 h-4"></i> Precedent
        </button>
        <button type="submit" class="inline-flex items-center gap-2 px-4 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
          <i data-lucide="save" class="w-4 h-4"></i> Enregistrer
        </button>
      </div>
    </div>

    {{ form_end(form) }}
  </div>
</div>

<script>
function showStep(step) {
  document.getElementById('step-1').classList.toggle('hidden', step !== 1);
  document.getElementById('step-2').classList.toggle('hidden', step !== 2);
  document.getElementById('step-ind-1').className = step === 1 ? 'step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-jessica-500 text-white font-semibold' : 'step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gray-200 text-gray-600 font-medium';
  document.getElementById('step-ind-2').className = step === 2 ? 'step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-jessica-500 text-white font-semibold' : 'step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gray-200 text-gray-600 font-medium';
}
</script>
{% endblock %}
{% block javascripts %}{{ parent() }}{{ encore_entry_script_tags('fieldset') }}{{ encore_entry_script_tags('add_bg') }}{% endblock %}
{% block stylesheets %}{{ parent() }}{{ encore_entry_link_tags('fieldset') }}{% endblock %}
