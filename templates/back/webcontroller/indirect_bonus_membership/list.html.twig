{% extends 'base.html.twig' %}
{% block title %}Indirect Bonus : Pourcentages sur les packs - RACS Health Global{% endblock %}
{% block page_title %}Indirect Bonus : Les pourcentages sur les packs de souscriptions{% endblock %}

{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">
  {% for type, messages in app.session.flashbag.all() %}
    {% for message in messages %}
      <div class="mx-5 px-4 py-3 rounded-lg text-sm font-medium {% if type == 'success' %}bg-green-50 text-green-700{% elseif type == 'danger' %}bg-red-50 text-red-700{% else %}bg-blue-50 text-blue-700{% endif %}">{{ message }}</div>
    {% endfor %}
  {% endfor %}

  <div class="flex flex-wrap items-center gap-3 px-5">
    {% if app.user and is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_JTWC_ADMIN') %}
      <a href="{{ path('indirect_bonus_membership_new') }}" class="inline-flex items-center gap-2 px-4 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors shadow-sm">
        <i data-lucide="plus-circle" class="w-4 h-4"></i> Parametrer les pourcentages sur les packs
      </a>
    {% endif %}
  </div>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Code</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-600">Generations</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-600">Valeurs</th>
            {% if app.user and is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_JTWC_ADMIN') %}
              <th class="px-4 py-3 text-center font-semibold text-gray-600">Actions</th>
            {% endif %}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {% for code, indBoMemberships in indirectBonusMemberships %}
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3 font-medium text-gray-800" {% if indBoMemberships|length > 1 %}rowspan="{{ indBoMemberships|length }}"{% endif %}>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-jessica-50 text-jessica-600">{{ code }}</span>
              </td>
              <td class="px-4 py-3 text-right text-gray-600">{{ indBoMemberships[0]['lvl'] }}</td>
              <td class="px-4 py-3 text-right text-gray-600">{{ indBoMemberships[0]['value'] }}</td>
              {% if app.user and is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_JTWC_ADMIN') %}
                <td class="px-4 py-3">
                  <div class="flex items-center justify-center gap-1">
                    <a href="{{ path('indirect_bonus_membership_edit', {'id': indBoMemberships[0]['id']}) }}" title="Modifier" class="p-1.5 rounded-lg text-blue-600 hover:bg-blue-50 transition-colors"><i data-lucide="pencil" class="w-4 h-4"></i></a>
                    <button type="button" title="Supprimer" class="p-1.5 rounded-lg text-red-500 hover:bg-red-50 transition-colors" onclick="openModal('delete-{{ indBoMemberships[0]['id'] }}')"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                    <div id="modal-delete-{{ indBoMemberships[0]['id'] }}" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
                      <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full mx-4 p-6">
                        <div class="flex items-center gap-3 mb-4"><div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center"><i data-lucide="alert-triangle" class="w-5 h-5 text-red-600"></i></div><h3 class="text-lg font-bold text-gray-800">Confirmer la suppression</h3></div>
                        <p class="text-sm text-gray-500 mb-6">Voulez-vous vraiment supprimer cette valeur ?</p>
                        <div class="flex gap-3 justify-end">
                          <button onclick="closeModal('delete-{{ indBoMemberships[0]['id'] }}')" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Annuler</button>
                          <form action="{{ path('indirect_bonus_membership_delete', {'id': indBoMemberships[0]['id']}) }}" method="post" class="inline">
                            <input type="hidden" name="_method" value="DELETE">
                            <input type="hidden" name="_jtwc_indirect_bonus_token" value="{{ csrf_token('jtwc_indirect_bonus-delete'~indBoMemberships[0]['id']) }}">
                            <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-red-500 rounded-lg hover:bg-red-600 transition-colors">Supprimer</button>
                          </form>
                        </div>
                      </div>
                    </div>
                  </div>
                </td>
              {% endif %}
            </tr>
            {% if indBoMemberships|length > 1 %}
              {% for indBoMembership in indBoMemberships|slice(1, indBoMemberships|length) %}
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-4 py-3 text-right text-gray-600">{{ indBoMembership['lvl'] }}</td>
                  <td class="px-4 py-3 text-right text-gray-600">{{ indBoMembership['value'] }}</td>
                  {% if app.user and is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_JTWC_ADMIN') %}
                    <td class="px-4 py-3">
                      <div class="flex items-center justify-center gap-1">
                        <a href="{{ path('indirect_bonus_membership_edit', {'id': indBoMembership['id']}) }}" title="Modifier" class="p-1.5 rounded-lg text-blue-600 hover:bg-blue-50 transition-colors"><i data-lucide="pencil" class="w-4 h-4"></i></a>
                        <button type="button" title="Supprimer" class="p-1.5 rounded-lg text-red-500 hover:bg-red-50 transition-colors" onclick="openModal('delete-{{ indBoMembership['id'] }}')"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                        <div id="modal-delete-{{ indBoMembership['id'] }}" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
                          <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full mx-4 p-6">
                            <div class="flex items-center gap-3 mb-4"><div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center"><i data-lucide="alert-triangle" class="w-5 h-5 text-red-600"></i></div><h3 class="text-lg font-bold text-gray-800">Confirmer la suppression</h3></div>
                            <p class="text-sm text-gray-500 mb-6">Voulez-vous vraiment supprimer cette valeur ?</p>
                            <div class="flex gap-3 justify-end">
                              <button onclick="closeModal('delete-{{ indBoMembership['id'] }}')" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Annuler</button>
                              <form action="{{ path('indirect_bonus_membership_delete', {'id': indBoMembership['id']}) }}" method="post" class="inline">
                                <input type="hidden" name="_method" value="DELETE">
                                <input type="hidden" name="_jtwc_indirect_bonus_token" value="{{ csrf_token('jtwc_indirect_bonus-delete'~indBoMembership['id']) }}">
                                <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-red-500 rounded-lg hover:bg-red-600 transition-colors">Supprimer</button>
                              </form>
                            </div>
                          </div>
                        </div>
                      </div>
                    </td>
                  {% endif %}
                </tr>
              {% endfor %}
            {% endif %}
          {% else %}
            <tr><td colspan="4" class="px-4 py-12 text-center"><div class="flex flex-col items-center gap-3"><i data-lucide="inbox" class="w-10 h-10 text-gray-300"></i><p class="text-sm text-gray-500">Aucune valeur definie pour l'instant</p></div></td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
<script>
function openModal(id) { const m = document.getElementById('modal-' + id); if (m) { m.classList.remove('hidden'); m.classList.add('flex'); } }
function closeModal(id) { const m = document.getElementById('modal-' + id); if (m) { m.classList.add('hidden'); m.classList.remove('flex'); } }
</script>
{% endblock %}
