{# Flash Messages #}
{% for type, messages in app.session.flashbag.all() %}
  {% for message in messages %}
    <div class="px-4 py-3 rounded-lg text-sm font-medium {% if type == 'success' %}bg-green-50 text-green-700{% elseif type == 'danger' %}bg-red-50 text-red-700{% else %}bg-blue-50 text-blue-700{% endif %}">
      {{ message }}
    </div>
  {% endfor %}
{% endfor %}

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  {{ form_start(form, {attr: {'novalidate': 'novalidate', 'id': 'form', 'class': 'divide-y divide-gray-100'}}) }}

  {# Step Indicators #}
  <div class="px-6 py-4 bg-gray-50">
    <div class="flex items-center gap-4 text-sm">
      <span class="step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-jessica-500 text-white font-semibold" id="step-ind-1">
        <span>1</span> Informations produit
      </span>
      <i data-lucide="chevron-right" class="w-4 h-4 text-gray-400"></i>
      <span class="step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gray-200 text-gray-600 font-medium" id="step-ind-2">
        <span>2</span> Infos complementaires
      </span>
    </div>
  </div>

  {# Step 1 #}
  <div id="step-1" class="p-6 space-y-5">
    <h3 class="text-base font-bold text-gray-800">Informations sur le produit</h3>
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.code.vars.label }}</label>
        {{ form_widget(form.code, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
        <div class="text-red-500 text-xs mt-1">{{ form_errors(form.code) }}</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.name.vars.label }}</label>
        {{ form_widget(form.name, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
        <div class="text-red-500 text-xs mt-1">{{ form_errors(form.name) }}</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.description.vars.label }}</label>
        {{ form_widget(form.description, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
        <div class="text-red-500 text-xs mt-1">{{ form_errors(form.description) }}</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.imageFile.vars.label }}</label>
        {{ form_widget(form.imageFile, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
        <div class="text-red-500 text-xs mt-1">{{ form_errors(form.imageFile) }}</div>
      </div>
    </div>
    <div class="flex justify-end pt-2">
      <button type="button" onclick="showStep(2)" class="inline-flex items-center gap-2 px-4 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
        Suivant
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </button>
    </div>
  </div>

  {# Step 2 #}
  <div id="step-2" class="p-6 space-y-5 hidden">
    <h3 class="text-base font-bold text-gray-800">Informations complementaires</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.distributorPrice.vars.label }}</label>
        {{ form_widget(form.distributorPrice, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
        <div class="text-red-500 text-xs mt-1">{{ form_errors(form.distributorPrice) }}</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.clientPrice.vars.label }}</label>
        {{ form_widget(form.clientPrice, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
        <div class="text-red-500 text-xs mt-1">{{ form_errors(form.clientPrice) }}</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.productSV.vars.label }}</label>
        {{ form_widget(form.productSV, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
        <div class="text-red-500 text-xs mt-1">{{ form_errors(form.productSV) }}</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.productSVBPA.vars.label }}</label>
        {{ form_widget(form.productSVBPA, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
        <div class="text-red-500 text-xs mt-1">{{ form_errors(form.productSVBPA) }}</div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.productCote.vars.label }}</label>
        {{ form_widget(form.productCote, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
        <div class="text-red-500 text-xs mt-1">{{ form_errors(form.productCote) }}</div>
      </div>
    </div>
    <div class="flex justify-between pt-2">
      <button type="button" onclick="showStep(1)" class="inline-flex items-center gap-2 px-4 py-2.5 bg-gray-100 text-gray-700 text-sm font-semibold rounded-lg hover:bg-gray-200 transition-colors">
        <i data-lucide="arrow-left" class="w-4 h-4"></i>
        Precedent
      </button>
      <button type="submit" class="inline-flex items-center gap-2 px-4 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
        <i data-lucide="save" class="w-4 h-4"></i>
        Enregistrer
      </button>
    </div>
  </div>

  {{ form_end(form) }}
</div>

<script>
function showStep(step) {
  document.getElementById('step-1').classList.toggle('hidden', step !== 1);
  document.getElementById('step-2').classList.toggle('hidden', step !== 2);
  document.getElementById('step-ind-1').className = step === 1
    ? 'step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-jessica-500 text-white font-semibold'
    : 'step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gray-200 text-gray-600 font-medium';
  document.getElementById('step-ind-2').className = step === 2
    ? 'step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-jessica-500 text-white font-semibold'
    : 'step-indicator inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-gray-200 text-gray-600 font-medium';
}
</script>
