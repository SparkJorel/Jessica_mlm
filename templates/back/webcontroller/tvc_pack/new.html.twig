{% extends 'base.html.twig' %}
{% block title %}Nouveau pourcentage TVC - RACS Health Global{% endblock %}
{% block page_title %}Nouveau pourcentage TVC{% endblock %}
{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="border-b border-gray-200 bg-gray-50 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-800">Enregistrement du pourcentage de calcul des TVC</h2>
    </div>
    <div class="p-6">
      {{ form_start(form, {attr: {'id': 'form', 'class': 'space-y-5'}}) }}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.membership.vars.label }}</label>
          {{ form_errors(form.membership) }}
          {{ form_widget(form.membership, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-jessica-500 focus:ring-1 focus:ring-jessica-500'}}) }}
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.value.vars.label }}</label>
          {{ form_errors(form.value) }}
          {{ form_widget(form.value, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-jessica-500 focus:ring-1 focus:ring-jessica-500'}}) }}
        </div>
      </div>
      <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-200">
        <a href="{{ path('membership_tvc_list') }}" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition">Annuler</a>
        <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-jessica-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-jessica-600 transition"><i data-lucide="save" class="w-4 h-4"></i>Enregistrer</button>
      </div>
      {{ form_end(form) }}
    </div>
  </div>
</div>
{% endblock %}
{% block javascripts %}
  {{ parent() }}
  {{ encore_entry_script_tags('validate') }}
{% endblock %}
