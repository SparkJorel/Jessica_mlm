{% extends 'base.html.twig' %}
{% block title %}Volumes totaux de commissions - RACS Health Global{% endblock %}
{% block page_title %}Volumes totaux de commissions{% endblock %}
{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">
  {% if app.user and is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_JTWC_ADMIN') %}
  <div class="flex items-center justify-between px-5 sm:px-6 pt-5 sm:pt-6">
    <div></div>
    <a href="{{ path('membership_tvc_create') }}" class="inline-flex items-center gap-2 rounded-lg bg-jessica-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-jessica-600 transition"><i data-lucide="plus" class="w-4 h-4"></i>Ajouter</a>
  </div>
  {% endif %}

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left" id="table-info">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 font-semibold text-gray-700">Membership</th>
            <th class="px-4 py-3 font-semibold text-gray-700">Valeur (%)</th>
            <th class="px-4 py-3 font-semibold text-gray-700">Statut</th>
            {% if app.user and is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_JTWC_ADMIN') %}
            <th class="px-4 py-3 font-semibold text-gray-700 text-right">Actions</th>
            {% endif %}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {% for tvc in tvcs %}
          <tr class="hover:bg-gray-50 transition">
            <td class="px-4 py-3 text-gray-800 font-medium">{{ tvc.membership.name }}</td>
            <td class="px-4 py-3 text-gray-600">{{ tvc.value }}</td>
            <td class="px-4 py-3">
              {% if tvc.status %}
                <span class="inline-flex items-center rounded-full bg-green-50 px-2.5 py-0.5 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">Active</span>
              {% else %}
                <span class="inline-flex items-center rounded-full bg-red-50 px-2.5 py-0.5 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/20">Desactive</span>
              {% endif %}
            </td>
            {% if app.user and is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_JTWC_ADMIN') %}
            <td class="px-4 py-3 text-right">
              <div class="inline-flex items-center gap-1">
                <a href="{{ path('membership_tvc_edit', {'id': tvc.id}) }}" class="p-1.5 rounded-md text-gray-500 hover:text-jessica-600 hover:bg-jessica-50 transition" title="Modifier"><i data-lucide="pencil" class="w-4 h-4"></i></a>
                <button type="button" onclick="openModal('deleteModal{{ tvc.id }}')" class="p-1.5 rounded-md text-gray-500 hover:text-red-600 hover:bg-red-50 transition" title="Supprimer"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
              </div>
              <!-- Delete Modal -->
              <div id="deleteModal{{ tvc.id }}" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
                <div class="bg-white rounded-xl shadow-xl max-w-md w-full mx-4 p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center"><i data-lucide="alert-triangle" class="w-5 h-5 text-red-600"></i></div>
                    <h3 class="text-lg font-semibold text-gray-900">Confirmation de suppression</h3>
                  </div>
                  <p class="text-sm text-gray-600 mb-6">Voulez-vous vraiment supprimer cette valeur ?</p>
                  <div class="flex items-center justify-end gap-3">
                    <button type="button" onclick="closeModal('deleteModal{{ tvc.id }}')" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition">Abandonner</button>
                    <form action="{{ path('membership_tvc_delete', {'id': tvc.id }) }}" method="post">
                      <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition">Confirmer</button>
                      <input type="hidden" name="_jtwc_membership_cost_token" value="{{ csrf_token('jtwc_membership_cost-delete'~tvc.id) }}" />
                    </form>
                  </div>
                </div>
              </div>
            </td>
            {% endif %}
          </tr>
          {% else %}
          <tr>
            <td colspan="{% if app.user and is_granted('IS_AUTHENTICATED_FULLY') and is_granted('ROLE_JTWC_ADMIN') %}4{% else %}3{% endif %}" class="px-4 py-12 text-center">
              <div class="flex flex-col items-center gap-3"><i data-lucide="inbox" class="w-10 h-10 text-gray-300"></i><p class="text-sm text-gray-500">Pas de volume commission disponible</p></div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
function openModal(id){document.getElementById(id).classList.remove('hidden');}
function closeModal(id){document.getElementById(id).classList.add('hidden');}
</script>
{% endblock %}
{% block javascripts %}
  {{ parent() }}
  {{ encore_entry_script_tags('datatable') }}
{% endblock %}
{% block stylesheets %}
  {{ parent() }}
  {{ encore_entry_link_tags('datatable') }}
{% endblock %}
