{% extends 'base.html.twig' %}
{% block title %}Mon reseau - RACS Health Global{% endblock %}
{% block page_title %}Mon reseau{% endblock %}
{% block nav_network %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">

  {# Action Bar #}
  <div class="flex items-center gap-3">
    <a href="{{ path('user_new_from_known_sponsor') }}" class="inline-flex items-center gap-2 px-4 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors shadow-sm">
      <i data-lucide="user-plus" class="w-4 h-4"></i>
      Ajouter un membre
    </a>
  </div>

  {# Data Table #}
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Nom & Prenoms</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden sm:table-cell">Sexe</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden md:table-cell">Email</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden md:table-cell">Telephone</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Etat</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden lg:table-cell">Ville</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden lg:table-cell">Pays</th>
            <th class="px-4 py-3 text-center font-semibold text-gray-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {% for user in users %}
            {% if app.user.rgt >= user.rgt %}
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-jessica-100 flex items-center justify-center text-xs font-bold text-jessica-600 flex-shrink-0">
                    {{ user.fullname|first|upper }}
                  </div>
                  <div>
                    <div class="font-semibold text-gray-800">{{ user.fullname }}</div>
                    <div class="text-xs text-gray-400 sm:hidden">{{ user.gender }}</div>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 text-gray-600 hidden sm:table-cell">{{ user.gender }}</td>
              <td class="px-4 py-3 text-gray-600 hidden md:table-cell">{{ user.email }}</td>
              <td class="px-4 py-3 text-gray-600 hidden md:table-cell">{{ user.mobilePhone }}</td>
              <td class="px-4 py-3">
                {% if user.activated %}
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-600">
                    <i data-lucide="check-circle-2" class="w-3 h-3"></i> Actif
                  </span>
                {% else %}
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-red-50 text-red-500">
                    <i data-lucide="x-circle" class="w-3 h-3"></i> Inactif
                  </span>
                {% endif %}
              </td>
              <td class="px-4 py-3 text-gray-600 hidden lg:table-cell">{{ user.city }}</td>
              <td class="px-4 py-3 text-gray-600 hidden lg:table-cell">{{ user.country }}</td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1">
                  {% if user.entryDate %}
                    {% set difference = date("now"|date()).diff(date(user.entryDate)) %}
                    {% set leftDays = difference.days %}
                  {% else %}
                    {% set leftDays = 999 %}
                  {% endif %}
                  {% if leftDays <= 2 %}
                    <a href="{{ path('user_edit', {'id': user.id}) }}" title="Modifier" class="p-1.5 rounded-lg text-blue-600 hover:bg-blue-50 transition-colors">
                      <i data-lucide="pencil" class="w-4 h-4"></i>
                    </a>
                  {% endif %}
                  {% if user.activated %}
                    <span class="p-1.5 text-green-500" title="Actif">
                      <i data-lucide="check-circle-2" class="w-4 h-4"></i>
                    </span>
                  {% else %}
                    <span class="p-1.5 text-amber-500" title="Inactif">
                      <i data-lucide="alert-circle" class="w-4 h-4"></i>
                    </span>
                  {% endif %}
                </div>
              </td>
            </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endblock %}
