{% extends 'base.html.twig' %}
{% block title %}Liste des membres - RACS Health Global{% endblock %}
{% block page_title %}Liste des membres{% endblock %}
{% block nav_members %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">

  {# Search Bar #}
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <form class="form-inline" role="form">
      {% include "back/webcontroller/search_user.html.twig" with {'form': formSearch} %}
    </form>
  </div>

  {# Action Bar #}
  <div class="flex flex-wrap items-center gap-3">
    {% if app.user and is_granted('IS_AUTHENTICATED_FULLY') and (is_granted('ROLE_JTWC_ADMIN') or is_granted('ROLE_JTWC_USER_SECRET')) %}
      <a href="{{ path('user_new_from_known_sponsor') }}" class="inline-flex items-center gap-2 px-4 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors shadow-sm">
        <i data-lucide="user-plus" class="w-4 h-4"></i>
        Ajouter un membre
      </a>
      <a href="{{ path('users_generate_code') }}" class="inline-flex items-center gap-2 px-4 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors shadow-sm">
        <i data-lucide="hash" class="w-4 h-4"></i>
        Generer code distributeur
      </a>
    {% endif %}
    {% if not activated %}
      <button class="inline-flex items-center gap-2 px-4 py-2.5 bg-accent-500 text-white text-sm font-semibold rounded-lg hover:bg-accent-600 transition-colors shadow-sm" type="button" id="validate_activation">
        <i data-lucide="check-circle" class="w-4 h-4"></i>
        Activer
      </button>
    {% endif %}
  </div>

  {# Data Table #}
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            {% if not activated %}
              <th class="px-4 py-3 text-left">
                <input type="checkbox" id="check_all" class="rounded border-gray-300 text-jessica-500 focus:ring-jessica-500">
              </th>
            {% endif %}
            <th class="px-4 py-3 text-left font-semibold text-gray-600">{{ knp_pagination_sortable(users, 'Nom & Prenoms', 'u.fullname') }}</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden lg:table-cell">Position</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden md:table-cell">Email</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden md:table-cell">Telephone</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden lg:table-cell">Upline</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden xl:table-cell">Sponsor</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Pack</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden xl:table-cell">Ville</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden xl:table-cell">Pays</th>
            {% if app.user and is_granted('IS_AUTHENTICATED_FULLY') and (is_granted('ROLE_JTWC_ADMIN') or is_granted('ROLE_JTWC_USER_SECRET')) %}
              <th class="px-4 py-3 text-center font-semibold text-gray-600">Actions</th>
            {% endif %}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {% for user in users %}
            <tr class="hover:bg-gray-50 transition-colors">
              {% if not activated %}
                <td class="px-4 py-3">
                  {% if not user.activated %}
                    <input type="checkbox" class="check_item rounded border-gray-300 text-jessica-500 focus:ring-jessica-500" value="{{ user.id }}">
                  {% endif %}
                </td>
              {% endif %}
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-jessica-100 flex items-center justify-center text-xs font-bold text-jessica-600 flex-shrink-0">
                    {{ user.fullname|first|upper }}
                  </div>
                  <div>
                    <div class="font-semibold text-gray-800">{{ user.fullname }}</div>
                    <div class="text-xs text-gray-400 md:hidden">{{ user.email }}</div>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 text-gray-600 hidden lg:table-cell">{{ user.position }}</td>
              <td class="px-4 py-3 text-gray-600 hidden md:table-cell">{{ user.email }}</td>
              <td class="px-4 py-3 text-gray-600 hidden md:table-cell">{{ user.mobilePhone }}</td>
              <td class="px-4 py-3 text-gray-600 hidden lg:table-cell">{% if user.upline %}{{ user.upline.fullname }}{% endif %}</td>
              <td class="px-4 py-3 text-gray-600 hidden xl:table-cell">{% if user.sponsor %}{{ user.sponsor.fullname }}{% endif %}</td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-jessica-50 text-jessica-600">{{ user.membership.code }}</span>
              </td>
              <td class="px-4 py-3 text-gray-600 hidden xl:table-cell">{{ user.city }}</td>
              <td class="px-4 py-3 text-gray-600 hidden xl:table-cell">{{ user.country }}</td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-1">
                  <a href="{{ path('user_edit', {'id': user.id}) }}" title="Modifier" class="p-1.5 rounded-lg text-blue-600 hover:bg-blue-50 transition-colors">
                    <i data-lucide="pencil" class="w-4 h-4"></i>
                  </a>
                  {% if not user.activated %}
                    <button type="button" title="Activer" class="p-1.5 rounded-lg text-accent-500 hover:bg-accent-50 transition-colors" onclick="openModal('activate-{{ user.id }}')">
                      <i data-lucide="toggle-right" class="w-4 h-4"></i>
                    </button>
                  {% else %}
                    <span class="p-1.5 text-green-500" title="Actif">
                      <i data-lucide="check-circle-2" class="w-4 h-4"></i>
                    </span>
                  {% endif %}
                  <button type="button" title="Reinitialiser le mot de passe" class="p-1.5 rounded-lg text-amber-600 hover:bg-amber-50 transition-colors" onclick="openModal('resetpwd-{{ user.id }}')">
                    <i data-lucide="key-round" class="w-4 h-4"></i>
                  </button>
                  <button type="button" title="Supprimer" class="p-1.5 rounded-lg text-red-500 hover:bg-red-50 transition-colors" onclick="openModal('delete-{{ user.id }}')">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                  </button>
                </div>

                {# Reset Password Modal #}
                <div id="modal-resetpwd-{{ user.id }}" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
                  <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full mx-4 p-6">
                    <div class="flex items-center gap-3 mb-4">
                      <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center">
                        <i data-lucide="key-round" class="w-5 h-5 text-amber-600"></i>
                      </div>
                      <h3 class="text-lg font-bold text-gray-800">Reinitialiser le mot de passe</h3>
                    </div>
                    <p class="text-sm text-gray-500 mb-4">Definir un nouveau mot de passe pour <strong>{{ user.fullname }}</strong></p>
                    <form action="{{ path('user_reset_password', {'id': user.id}) }}" method="post">
                      <input type="hidden" name="_jtwc_reset_password_token" value="{{ csrf_token('jtwc_reset_password-'~user.id) }}">
                      <div class="mb-4">
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Nouveau mot de passe</label>
                        <div class="relative pwd-toggle-wrap">
                          <input type="password" name="new_password" required minlength="6" placeholder="Minimum 6 caracteres" class="w-full rounded-lg border border-gray-300 px-3 pr-10 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition">
                          <button type="button" class="pwd-toggle absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 transition-colors" tabindex="-1">
                            <i data-lucide="eye" class="w-4 h-4"></i>
                          </button>
                        </div>
                      </div>
                      <div class="flex gap-3 justify-end">
                        <button type="button" onclick="closeModal('resetpwd-{{ user.id }}')" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Annuler</button>
                        <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-amber-500 rounded-lg hover:bg-amber-600 transition-colors">Reinitialiser</button>
                      </div>
                    </form>
                  </div>
                </div>

                {# Activate Modal #}
                {% if not user.activated %}
                <div id="modal-activate-{{ user.id }}" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
                  <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full mx-4 p-6">
                    <div class="flex items-center gap-3 mb-4">
                      <div class="w-10 h-10 rounded-full bg-accent-100 flex items-center justify-center">
                        <i data-lucide="user-check" class="w-5 h-5 text-accent-600"></i>
                      </div>
                      <h3 class="text-lg font-bold text-gray-800">Activer ce membre ?</h3>
                    </div>
                    <p class="text-sm text-gray-500 mb-6">Voulez-vous activer <strong>{{ user.fullname }}</strong> ?</p>
                    <div class="flex gap-3 justify-end">
                      <button onclick="closeModal('activate-{{ user.id }}')" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Annuler</button>
                      <a href="{{ path('user_activated', {'id': user.id}) }}" class="px-4 py-2 text-sm font-semibold text-white bg-jessica-500 rounded-lg hover:bg-jessica-600 transition-colors">Confirmer</a>
                    </div>
                  </div>
                </div>
                {% endif %}

                {# Delete Modal #}
                <div id="modal-delete-{{ user.id }}" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
                  <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full mx-4 p-6">
                    <div class="flex items-center gap-3 mb-4">
                      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center">
                        <i data-lucide="alert-triangle" class="w-5 h-5 text-red-600"></i>
                      </div>
                      <h3 class="text-lg font-bold text-gray-800">Supprimer ce membre ?</h3>
                    </div>
                    <p class="text-sm text-gray-500 mb-6">Cette action est irreversible. Voulez-vous supprimer <strong>{{ user.fullname }}</strong> ?</p>
                    <div class="flex gap-3 justify-end">
                      <button onclick="closeModal('delete-{{ user.id }}')" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Annuler</button>
                      <form action="{{ path('user_delete', {'id': user.id}) }}" method="post" class="inline">
                        <input type="hidden" name="_method" value="DELETE">
                        <input type="hidden" name="_jtwc_user_token" value="{{ csrf_token('jtwc_user-delete'~user.id) }}">
                        <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-red-500 rounded-lg hover:bg-red-600 transition-colors">Supprimer</button>
                      </form>
                    </div>
                  </div>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {# Pagination #}
    <div class="px-5 py-4 border-t border-gray-100 flex justify-center">
      {{ knp_pagination_render(users) }}
    </div>
  </div>
</div>

<script>
function openModal(id) {
  const m = document.getElementById('modal-' + id);
  if (m) { m.classList.remove('hidden'); m.classList.add('flex'); }
}
function closeModal(id) {
  const m = document.getElementById('modal-' + id);
  if (m) { m.classList.add('hidden'); m.classList.remove('flex'); }
}

document.querySelectorAll('.pwd-toggle').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var input = this.parentElement.querySelector('input');
    var isHidden = input.type === 'password';
    input.type = isHidden ? 'text' : 'password';
    this.innerHTML = isHidden
      ? '<i data-lucide="eye-off" class="w-4 h-4"></i>'
      : '<i data-lucide="eye" class="w-4 h-4"></i>';
    lucide.createIcons();
    input.focus();
  });
});
</script>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('activate_user') }}
{% endblock %}
