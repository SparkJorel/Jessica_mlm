{% extends 'base.html.twig' %}
{% block title %}Modifier le mot de passe - RACS Health Global{% endblock %}
{% block page_title %}Modifier le mot de passe{% endblock %}
{% block nav_account %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="max-w-lg mx-auto -m-5 sm:-m-6">
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-jessica-50 flex items-center justify-center">
        <i data-lucide="lock" class="w-5 h-5 text-jessica-500"></i>
      </div>
      <div>
        <h2 class="text-sm font-bold text-gray-800">Modification du mot de passe</h2>
        <p class="text-xs text-gray-400">Choisissez un mot de passe securise</p>
      </div>
    </div>
    <div class="p-6">
      {{ form_start(form, {attr: {'id': 'form', 'class': 'space-y-5', 'novalidate': 'novalidate'}}) }}
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Mot de passe actuel</label>
          <div class="relative pwd-toggle-wrap">
            {{ form_widget(form.oldPassword, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 pr-10 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition', 'placeholder': 'Entrez votre mot de passe actuel'}}) }}
            <button type="button" class="pwd-toggle absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 transition-colors" tabindex="-1">
              <i data-lucide="eye" class="w-4 h-4"></i>
            </button>
          </div>
          {{ form_errors(form.oldPassword) }}
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Nouveau mot de passe</label>
          <div class="relative pwd-toggle-wrap">
            {{ form_widget(form.password.first, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 pr-10 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition', 'placeholder': 'Entrez le nouveau mot de passe'}}) }}
            <button type="button" class="pwd-toggle absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 transition-colors" tabindex="-1">
              <i data-lucide="eye" class="w-4 h-4"></i>
            </button>
          </div>
          {{ form_errors(form.password.first) }}
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Confirmer le mot de passe</label>
          <div class="relative pwd-toggle-wrap">
            {{ form_widget(form.password.second, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 pr-10 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition', 'placeholder': 'Confirmez le nouveau mot de passe'}}) }}
            <button type="button" class="pwd-toggle absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 transition-colors" tabindex="-1">
              <i data-lucide="eye" class="w-4 h-4"></i>
            </button>
          </div>
          {{ form_errors(form.password.second) }}
        </div>
        <div class="pt-2">
          <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors shadow-sm">
            <i data-lucide="check" class="w-4 h-4"></i> Enregistrer
          </button>
        </div>
      {{ form_end(form) }}
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
<script>
document.querySelectorAll('.pwd-toggle').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var input = this.parentElement.querySelector('input');
    var isHidden = input.type === 'password';
    input.type = isHidden ? 'text' : 'password';
    this.innerHTML = isHidden
      ? '<i data-lucide="eye-off" class="w-4 h-4"></i>'
      : '<i data-lucide="eye" class="w-4 h-4"></i>';
    lucide.createIcons();
    input.focus();
  });
});
</script>
{% endblock %}
