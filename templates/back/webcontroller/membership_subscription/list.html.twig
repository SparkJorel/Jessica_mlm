{% extends 'base.html.twig' %}
{% block title %}Souscriptions - RACS Health Global{% endblock %}
{% block page_title %}{% if is_granted('ROLE_JTWC_ADMIN') or is_granted('ROLE_JTWC_USER_SECRET') %}Liste des souscriptions{% else %}Souscriptions personnelles{% endif %}{% endblock %}
{% block nav_subscriptions %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">

  {# Search #}
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <form novalidate="novalidate" class="form-inline" role="form">
      {% include "back/webcontroller/search_user.html.twig" with {'form': formSearch} %}
    </form>
  </div>

  {# Subscriptions Table #}
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left font-semibold text-gray-600">{{ knp_pagination_sortable(mbship_subs, 'Utilisateur', 'u.fullname') }}</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Membership</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-600">Prix</th>
            <th class="px-4 py-3 text-center font-semibold text-gray-600">Upgrade</th>
            <th class="px-4 py-3 text-center font-semibold text-gray-600">Active</th>
            {% if is_granted('ROLE_JTWC_ADMIN') or is_granted('ROLE_JTWC_USER_SECRET') %}
            <th class="px-4 py-3 text-center font-semibold text-gray-600">Paye</th>
            <th class="px-4 py-3 text-center font-semibold text-gray-600">Actions</th>
            {% endif %}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {% for mbship_sub in mbship_subs %}
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-jessica-100 flex items-center justify-center text-xs font-bold text-jessica-600 flex-shrink-0">{{ mbship_sub.member.fullname|first|upper }}</div>
                <div>
                  <div class="font-semibold text-gray-800">{{ mbship_sub.member.fullname }}</div>
                  <div class="text-xs text-gray-400 sm:hidden">{{ mbship_sub.membership.name }}</div>
                </div>
              </div>
            </td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-jessica-50 text-jessica-600">{{ mbship_sub.membership.name }}</span>
            </td>
            <td class="px-4 py-3 text-right font-semibold text-gray-800">{% if mbship_sub.price is defined %}{{ mbship_sub.price|number_format(0, ',', '.') }}{% endif %}</td>
            <td class="px-4 py-3 text-center">
              {% if mbship_sub.upgraded %}
                <span class="text-green-500"><i data-lucide="check-circle-2" class="w-4 h-4 inline"></i></span>
              {% else %}
                <span class="text-gray-300"><i data-lucide="minus" class="w-4 h-4 inline"></i></span>
              {% endif %}
            </td>
            <td class="px-4 py-3 text-center">
              {% if mbship_sub.state %}
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-600"><i data-lucide="check" class="w-3 h-3"></i> Oui</span>
              {% else %}
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-50 text-amber-600"><i data-lucide="clock" class="w-3 h-3"></i> Non</span>
              {% endif %}
            </td>
            {% if is_granted('ROLE_JTWC_ADMIN') or is_granted('ROLE_JTWC_USER_SECRET') %}
            <td class="px-4 py-3 text-center">
              {% if not mbship_sub.paid %}
                <button type="button" class="p-1.5 rounded-lg text-accent-500 hover:bg-accent-50 transition-colors" onclick="openModal('activate-sub-{{ mbship_sub.id }}')">
                  <i data-lucide="toggle-right" class="w-4 h-4"></i>
                </button>
                <div id="modal-activate-sub-{{ mbship_sub.id }}" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
                  <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full mx-4 p-6">
                    <div class="flex items-center gap-3 mb-4">
                      <div class="w-10 h-10 rounded-full bg-accent-100 flex items-center justify-center"><i data-lucide="credit-card" class="w-5 h-5 text-accent-600"></i></div>
                      <h3 class="text-lg font-bold text-gray-800">Activer cette souscription ?</h3>
                    </div>
                    <p class="text-sm text-gray-500 mb-6">Voulez-vous activer le paiement pour <strong>{{ mbship_sub.member.fullname }}</strong> ?</p>
                    <div class="flex gap-3 justify-end">
                      <button onclick="closeModal('activate-sub-{{ mbship_sub.id }}')" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Annuler</button>
                      <a href="{{ path('membership_subscription_activated', {'id': mbship_sub.id}) }}" class="px-4 py-2 text-sm font-semibold text-white bg-jessica-500 rounded-lg hover:bg-jessica-600 transition-colors">Confirmer</a>
                    </div>
                  </div>
                </div>
              {% else %}
                <span class="text-green-500"><i data-lucide="check-circle-2" class="w-4 h-4 inline"></i></span>
              {% endif %}
            </td>
            <td class="px-4 py-3 text-center">
              {% if mbship_sub.isUpgradable %}
                <button type="button" class="inline-flex items-center gap-1 px-2 py-1 text-xs font-semibold text-blue-600 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors" onclick="openModal('upgrade-sub-{{ mbship_sub.id }}')">
                  <i data-lucide="arrow-up-circle" class="w-3 h-3"></i> Upgrade
                </button>
                <div id="modal-upgrade-sub-{{ mbship_sub.id }}" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
                  <div class="bg-white rounded-2xl shadow-xl max-w-md w-full mx-4 p-6">
                    <div class="flex items-center gap-3 mb-4">
                      <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center"><i data-lucide="arrow-up-circle" class="w-5 h-5 text-blue-600"></i></div>
                      <h3 class="text-lg font-bold text-gray-800">Upgrade de souscription</h3>
                    </div>
                    <form action="{{ path('membership_subscription_upgrade') }}" method="post" class="space-y-4">
                      {% if is_granted('ROLE_JTWC_ADMIN') %}
                      <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Client</label>
                        <input type="text" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" name="client" value="{{ mbship_sub.member.fullname ~ ' (' ~ mbship_sub.member.id ~ ')' }}">
                      </div>
                      {% endif %}
                      <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Pack d'inscription</label>
                        <select class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" name="pack_inscription">
                          <option value="----">Choix du pack</option>
                          {% for p in mbship_sub.membershipUp %}
                          <option value="{{ p['id'] }}">{{ p['name'] }}</option>
                          {% endfor %}
                        </select>
                      </div>
                      <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Reste a payer</label>
                        <input type="text" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" name="price">
                      </div>
                      <div class="flex gap-3 justify-end pt-2">
                        <button type="button" onclick="closeModal('upgrade-sub-{{ mbship_sub.id }}')" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Annuler</button>
                        <input type="hidden" name="_jtwc_mb_subscription_token" value="{{ csrf_token('jtwc_mb_subscription-upgrade'~mbship_sub.id) }}">
                        <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-jessica-500 rounded-lg hover:bg-jessica-600 transition-colors">Confirmer</button>
                      </div>
                    </form>
                  </div>
                </div>
              {% endif %}
            </td>
            {% endif %}
          </tr>
          {% else %}
          <tr>
            <td colspan="{% if is_granted('ROLE_JTWC_ADMIN') or is_granted('ROLE_JTWC_USER_SECRET') %}7{% else %}5{% endif %}" class="px-5 py-8 text-center text-sm text-gray-400">
              <i data-lucide="inbox" class="w-8 h-8 mx-auto mb-2 opacity-40"></i>
              <p>Aucune souscription disponible</p>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class="px-5 py-4 border-t border-gray-100 flex justify-center">
      {{ knp_pagination_render(mbship_subs) }}
    </div>
  </div>
</div>

<script>
function openModal(id) { const m = document.getElementById('modal-' + id); if (m) { m.classList.remove('hidden'); m.classList.add('flex'); } }
function closeModal(id) { const m = document.getElementById('modal-' + id); if (m) { m.classList.add('hidden'); m.classList.remove('flex'); } }
</script>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('update_price') }}
{% endblock %}
