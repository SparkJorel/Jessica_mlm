{% extends 'base.html.twig' %}
{% block title %}Modification grade - RACS Health Global{% endblock %}
{% block page_title %}Modification d'un grade{% endblock %}
{% block main %}
<div class="max-w-3xl mx-auto -m-5 sm:-m-6">
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">

    {{ form_start(form, {attr: {'novalidate': 'novalidate', 'id': 'form', 'class': 'wizard-form'}}) }}

    {# Stepper #}
    <div class="border-b border-gray-200 px-6 py-4">
      <div class="flex items-center justify-between">
        <button type="button" class="step-indicator active flex items-center gap-2 text-sm font-semibold text-jessica-600" data-step="0">
          <span class="w-7 h-7 rounded-full bg-jessica-500 text-white flex items-center justify-center text-xs font-bold">1</span>
          <span class="hidden sm:inline">Informations</span>
        </button>
        <div class="flex-1 h-px bg-gray-200 mx-3"></div>
        <button type="button" class="step-indicator flex items-center gap-2 text-sm font-medium text-gray-400" data-step="1">
          <span class="w-7 h-7 rounded-full bg-gray-200 text-gray-500 flex items-center justify-center text-xs font-bold">2</span>
          <span class="hidden sm:inline">Complement</span>
        </button>
      </div>
    </div>

    {# Step 1 #}
    <fieldset class="wizard-step p-6 space-y-5" data-step="0">
      <h2 class="text-lg font-bold text-gray-800 flex items-center gap-2">
        <i data-lucide="award" class="w-5 h-5 text-jessica-500"></i>
        Informations sur le grade
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.commercialName.vars.label }}</label>
          {{ form_widget(form.commercialName, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
          {{ form_errors(form.commercialName) }}
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.technicalName.vars.label }}</label>
          {{ form_widget(form.technicalName, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
          {{ form_errors(form.technicalName) }}
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.weight.vars.label }}</label>
          {{ form_widget(form.weight, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
          {{ form_errors(form.weight) }}
        </div>
        <div class="flex items-center gap-2 pt-6">
          {{ form_widget(form.rewardable) }}
        </div>
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.description.vars.label }}</label>
          {{ form_widget(form.description, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
          {{ form_errors(form.description) }}
        </div>
      </div>
      <div class="flex justify-end pt-2">
        <button type="button" class="next inline-flex items-center gap-2 px-5 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
          Suivant <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
      </div>
    </fieldset>

    {# Step 2 #}
    <fieldset class="wizard-step p-6 space-y-5 hidden" data-step="1">
      <h2 class="text-lg font-bold text-gray-800 flex items-center gap-2">
        <i data-lucide="settings" class="w-5 h-5 text-jessica-500"></i>
        Informations additionnelles
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.maintenance.vars.label }}</label>
          {{ form_widget(form.maintenance, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
          {{ form_errors(form.maintenance) }}
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.lvl.vars.label }}</label>
          {{ form_widget(form.lvl, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
          {{ form_errors(form.lvl) }}
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.sv.vars.label }}</label>
          {{ form_widget(form.sv, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
          {{ form_errors(form.sv) }}
        </div>
      </div>
      <div class="flex justify-between pt-2">
        <button type="button" class="previous inline-flex items-center gap-2 px-5 py-2.5 bg-gray-100 text-gray-700 text-sm font-semibold rounded-lg hover:bg-gray-200 transition-colors">
          <i data-lucide="arrow-left" class="w-4 h-4"></i> Precedent
        </button>
        <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors shadow-sm">
          <i data-lucide="check" class="w-4 h-4"></i> Enregistrer
        </button>
      </div>
    </fieldset>

    {{ form_end(form) }}
  </div>
</div>
{% endblock %}
