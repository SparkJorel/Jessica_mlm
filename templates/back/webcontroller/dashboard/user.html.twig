{% extends 'base.html.twig' %}

{% block title %}Mon Dashboard - RACS Health Global{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}
{% block nav_dashboard %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="space-y-6 -m-5 sm:-m-6">

  {# Welcome Banner #}
  <div class="bg-gradient-to-br from-jessica-700 via-jessica-500 to-jessica-400 rounded-2xl p-6 sm:p-8 text-white relative overflow-hidden">
    <div class="absolute -top-16 -right-16 w-64 h-64 bg-white/5 rounded-full"></div>
    <div class="absolute -bottom-20 right-20 w-48 h-48 bg-white/[0.03] rounded-full"></div>
    <div class="relative z-10 flex flex-col sm:flex-row sm:items-center gap-4">
      {% if user.imageName %}
        <img src="{{ asset('uploads/users/' ~ user.imageName) }}" alt="" class="w-16 h-16 rounded-2xl object-cover border-2 border-white/30 shadow-lg flex-shrink-0">
      {% else %}
        <div class="w-16 h-16 rounded-2xl bg-white/10 border-2 border-white/30 shadow-lg flex-shrink-0 flex items-center justify-center">
          <i data-lucide="user" class="w-8 h-8 text-white/60"></i>
        </div>
      {% endif %}
      <div>
        <h1 class="text-xl sm:text-2xl font-bold mb-1">Bienvenue, {{ user.fullname }} !</h1>
        <div class="flex flex-wrap items-center gap-3 text-sm">
          <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm rounded-lg px-3 py-1.5">
            <i data-lucide="award" class="w-4 h-4"></i>
            {{ membership.name|default('Consommateur') }}
          </span>
          {% if user.codeDistributor %}
          <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm rounded-lg px-3 py-1.5">
            <i data-lucide="hash" class="w-4 h-4"></i>
            {{ user.codeDistributor }}
          </span>
          {% endif %}
          {% if user.activated %}
          <span class="inline-flex items-center gap-1.5 bg-green-500/20 rounded-lg px-3 py-1.5 text-green-100">
            <i data-lucide="check-circle-2" class="w-4 h-4"></i>
            Actif
          </span>
          {% else %}
          <span class="inline-flex items-center gap-1.5 bg-red-500/20 rounded-lg px-3 py-1.5 text-red-200">
            <i data-lucide="alert-circle" class="w-4 h-4"></i>
            Inactif
          </span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  {# KPI Stats Cards #}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

    {# Direct Downline #}
    <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-jessica-50 flex items-center justify-center flex-shrink-0">
          <i data-lucide="user-check" class="w-6 h-6 text-jessica-500"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Filleuls directs</p>
          <p class="text-2xl font-bold text-gray-900 mt-0.5">{{ directDownline }}</p>
          <span class="text-xs text-gray-400 mt-1">parraines par vous</span>
        </div>
      </div>
    </div>

    {# Network Size #}
    <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center flex-shrink-0">
          <i data-lucide="network" class="w-6 h-6 text-blue-600"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Mon reseau</p>
          <p class="text-2xl font-bold text-gray-900 mt-0.5">{{ networkSize }}</p>
          <span class="text-xs text-gray-400 mt-1">membres au total</span>
        </div>
      </div>
    </div>

    {# Sponsoring Bonus #}
    <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-accent-50 flex items-center justify-center flex-shrink-0">
          <i data-lucide="gift" class="w-6 h-6 text-accent-500"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Bonus parrainage</p>
          <p class="text-2xl font-bold text-gray-900 mt-0.5">{{ mySponsoringBonus|number_format(0, ',', '.') }} <span class="text-sm font-semibold text-gray-400">F</span></p>
          <span class="text-xs text-gray-400 mt-1">total cumule</span>
        </div>
      </div>
    </div>

    {# My Orders #}
    <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-purple-50 flex items-center justify-center flex-shrink-0">
          <i data-lucide="shopping-bag" class="w-6 h-6 text-purple-600"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Mes commandes</p>
          <p class="text-2xl font-bold text-gray-900 mt-0.5">{{ myOrdersCount }}</p>
          <span class="text-xs text-gray-400 mt-1">commandes passees</span>
        </div>
      </div>
    </div>
  </div>

  {# Quick Actions #}
  <div>
    <h2 class="text-lg font-bold text-gray-900 mb-3">Actions rapides</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
      <a href="{{ path('user_new_from_known_sponsor') }}" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 hover:border-jessica-400 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 group">
        <div class="w-10 h-10 rounded-lg bg-jessica-50 flex items-center justify-center group-hover:bg-jessica-100 transition-colors">
          <i data-lucide="user-plus" class="w-5 h-5 text-jessica-500"></i>
        </div>
        <div>
          <div class="text-sm font-semibold text-gray-800">Parrainer</div>
          <div class="text-xs text-gray-400">Ajouter un filleul</div>
        </div>
      </a>
      <a href="{{ path('genealogy_tree') }}" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 hover:border-blue-400 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 group">
        <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center group-hover:bg-blue-100 transition-colors">
          <i data-lucide="git-branch" class="w-5 h-5 text-blue-600"></i>
        </div>
        <div>
          <div class="text-sm font-semibold text-gray-800">Mon arbre</div>
          <div class="text-xs text-gray-400">Genealogie du reseau</div>
        </div>
      </a>
      <a href="{{ path('products_all') }}" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 hover:border-accent-400 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 group">
        <div class="w-10 h-10 rounded-lg bg-accent-50 flex items-center justify-center group-hover:bg-accent-100 transition-colors">
          <i data-lucide="package" class="w-5 h-5 text-accent-500"></i>
        </div>
        <div>
          <div class="text-sm font-semibold text-gray-800">Boutique</div>
          <div class="text-xs text-gray-400">Commander des produits</div>
        </div>
      </a>
      <a href="{{ path('view_own_recap') }}" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 hover:border-purple-400 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 group">
        <div class="w-10 h-10 rounded-lg bg-purple-50 flex items-center justify-center group-hover:bg-purple-100 transition-colors">
          <i data-lucide="bar-chart-3" class="w-5 h-5 text-purple-600"></i>
        </div>
        <div>
          <div class="text-sm font-semibold text-gray-800">Mes bonus</div>
          <div class="text-xs text-gray-400">Recapitulatif complet</div>
        </div>
      </a>
    </div>
  </div>

  {# Two columns: Account Info + Recent Bonuses #}
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    {# Account Info #}
    <div class="bg-white rounded-xl border border-gray-200">
      <div class="px-5 py-4 border-b border-gray-100">
        <h3 class="text-sm font-bold text-gray-800">Mon compte</h3>
      </div>
      <div class="p-5 space-y-4">
        <div class="flex items-center justify-between py-2">
          <span class="text-sm text-gray-500">Pack</span>
          <span class="text-sm font-semibold text-gray-800 inline-flex items-center gap-1.5">
            <i data-lucide="crown" class="w-4 h-4 text-accent-500"></i>
            {{ membership.name|default('—') }}
          </span>
        </div>
        <div class="border-t border-gray-50"></div>
        <div class="flex items-center justify-between py-2">
          <span class="text-sm text-gray-500">Grade</span>
          <span class="text-sm font-semibold text-gray-800">{{ user.userGrade.commercialName|default('—') }}</span>
        </div>
        <div class="border-t border-gray-50"></div>
        <div class="flex items-center justify-between py-2">
          <span class="text-sm text-gray-500">Code distributeur</span>
          <span class="text-sm font-mono font-bold text-jessica-500">{{ user.codeDistributor|default('Non genere') }}</span>
        </div>
        <div class="border-t border-gray-50"></div>
        <div class="flex items-center justify-between py-2">
          <span class="text-sm text-gray-500">Date d'activation</span>
          <span class="text-sm font-semibold text-gray-800">
            {% if user.dateActivation %}{{ user.dateActivation|date('d/m/Y') }}{% else %}—{% endif %}
          </span>
        </div>
        <div class="border-t border-gray-50"></div>
        <div class="flex items-center justify-between py-2">
          <span class="text-sm text-gray-500">Parrain</span>
          <span class="text-sm font-semibold text-gray-800">{{ user.sponsor.fullname|default('—') }}</span>
        </div>
        {% if activeSubscription %}
        <div class="border-t border-gray-50"></div>
        <div class="flex items-center justify-between py-2">
          <span class="text-sm text-gray-500">Souscription</span>
          <span class="inline-flex items-center gap-1 text-xs font-semibold px-2.5 py-1 rounded-full bg-jessica-50 text-jessica-600">
            <i data-lucide="check" class="w-3 h-3"></i>
            Payee — {{ activeSubscription.price|number_format(0, ',', '.') }} FCFA
          </span>
        </div>
        {% endif %}
      </div>
    </div>

    {# Recent Sponsoring Bonuses #}
    <div class="bg-white rounded-xl border border-gray-200">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <h3 class="text-sm font-bold text-gray-800">Bonus parrainage recents</h3>
        <a href="{{ path('bonus_parrainage_user') }}" class="text-xs font-semibold text-jessica-500 hover:text-jessica-600 transition-colors">Voir tout</a>
      </div>
      <div class="divide-y divide-gray-50">
        {% for bonus in recentBonuses %}
        <div class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50 transition-colors">
          <div class="w-8 h-8 rounded-full bg-accent-100 flex items-center justify-center flex-shrink-0">
            <i data-lucide="gift" class="w-4 h-4 text-accent-600"></i>
          </div>
          <div class="min-w-0 flex-1">
            <div class="text-sm font-semibold text-gray-800 truncate">{{ bonus.sponsorised }}</div>
            <div class="text-xs text-gray-400">{{ bonus.membership }}</div>
          </div>
          <div class="text-right flex-shrink-0">
            <div class="text-sm font-bold text-jessica-500">+{{ bonus.value|number_format(0, ',', '.') }} F</div>
            <div class="text-xs text-gray-400">
              {% if bonus.dateActivation %}{{ bonus.dateActivation|date('d/m/Y') }}{% endif %}
            </div>
          </div>
        </div>
        {% else %}
        <div class="px-5 py-8 text-center text-sm text-gray-400">
          <i data-lucide="inbox" class="w-8 h-8 mx-auto mb-2 opacity-40"></i>
          <p>Aucun bonus de parrainage</p>
        </div>
        {% endfor %}
      </div>
    </div>

  </div>

  {# Cycle info (if available) #}
  {% if currentCycle %}
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="flex items-center gap-3 mb-4">
      <i data-lucide="calendar" class="w-5 h-5 text-gray-400"></i>
      <h3 class="text-sm font-bold text-gray-800">Cycle en cours</h3>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="text-center p-4 bg-gray-50 rounded-xl">
        <div class="text-sm font-bold text-gray-800">{{ currentCycle.startedAt|date('d/m/Y') }}</div>
        <div class="text-xs text-gray-400 mt-1">Debut</div>
      </div>
      <div class="text-center p-4 bg-gray-50 rounded-xl">
        <div class="text-sm font-bold text-gray-800">{{ currentCycle.endedAt|date('d/m/Y') }}</div>
        <div class="text-xs text-gray-400 mt-1">Fin</div>
      </div>
      <div class="text-center p-4 bg-gray-50 rounded-xl">
        <div class="text-sm font-bold {% if currentCycle.closed %}text-red-500{% else %}text-jessica-500{% endif %}">
          {% if currentCycle.closed %}Cloture{% else %}En cours{% endif %}
        </div>
        <div class="text-xs text-gray-400 mt-1">Statut</div>
      </div>
      <div class="text-center p-4 bg-gray-50 rounded-xl">
        <div class="text-sm font-bold text-gray-800">{% if currentCycle.weekly %}Hebdomadaire{% else %}Mensuel{% endif %}</div>
        <div class="text-xs text-gray-400 mt-1">Type</div>
      </div>
    </div>
  </div>
  {% endif %}

</div>
{% endblock %}
