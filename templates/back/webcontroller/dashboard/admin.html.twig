{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin - RACS Health Global{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}
{% block nav_dashboard %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="space-y-6 -m-5 sm:-m-6">

  {# Welcome Banner #}
  <div class="bg-gradient-to-br from-jessica-700 via-jessica-500 to-jessica-400 rounded-2xl p-6 sm:p-8 text-white relative overflow-hidden">
    <div class="absolute -top-16 -right-16 w-64 h-64 bg-white/5 rounded-full"></div>
    <div class="absolute -bottom-20 right-20 w-48 h-48 bg-white/[0.03] rounded-full"></div>
    <div class="relative z-10">
      <h1 class="text-xl sm:text-2xl font-bold mb-1">Bonjour, {{ user.fullname }} !</h1>
      <p class="text-white/70 text-sm sm:text-base">Bienvenue sur le tableau de bord administrateur de RACS Health Global.</p>
      {% if currentCycle %}
      <div class="flex flex-wrap items-center gap-4 mt-4">
        <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-lg px-3 py-2 text-sm">
          <i data-lucide="calendar" class="w-4 h-4"></i>
          <span>Cycle actuel : {{ currentCycle.startedAt|date('d/m/Y') }} — {{ currentCycle.endedAt|date('d/m/Y') }}</span>
        </div>
        <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-lg px-3 py-2 text-sm">
          {% if currentCycle.closed %}
            <i data-lucide="lock" class="w-4 h-4 text-red-300"></i>
            <span class="text-red-200">Cloture</span>
          {% else %}
            <i data-lucide="unlock" class="w-4 h-4 text-green-300"></i>
            <span class="text-green-200">En cours</span>
          {% endif %}
        </div>
      </div>
      {% endif %}
    </div>
  </div>

  {# KPI Stats Cards #}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {# Total Members #}
    <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-jessica-50 flex items-center justify-center flex-shrink-0">
          <i data-lucide="users" class="w-6 h-6 text-jessica-500"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Total membres</p>
          <p class="text-2xl font-bold text-gray-900 mt-0.5">{{ totalMembers }}</p>
          <span class="inline-flex items-center gap-1 text-xs font-semibold mt-1 px-2 py-0.5 rounded-full bg-jessica-50 text-jessica-600">
            <i data-lucide="check-circle-2" class="w-3 h-3"></i>
            {{ activeMembers }} actifs
          </span>
        </div>
      </div>
    </div>

    {# Revenue #}
    <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-accent-50 flex items-center justify-center flex-shrink-0">
          <i data-lucide="banknote" class="w-6 h-6 text-accent-500"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Chiffre d'affaires</p>
          <p class="text-2xl font-bold text-gray-900 mt-0.5">{{ totalRevenue|number_format(0, ',', '.') }} <span class="text-sm font-semibold text-gray-400">FCFA</span></p>
          <span class="inline-flex items-center gap-1 text-xs font-semibold mt-1 px-2 py-0.5 rounded-full bg-amber-50 text-amber-600">
            <i data-lucide="clock" class="w-3 h-3"></i>
            {{ pendingSubscriptions }} en attente
          </span>
        </div>
      </div>
    </div>

    {# Orders #}
    <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center flex-shrink-0">
          <i data-lucide="shopping-bag" class="w-6 h-6 text-blue-600"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Commandes</p>
          <p class="text-2xl font-bold text-gray-900 mt-0.5">{{ totalOrders }}</p>
          <span class="text-xs text-gray-400 mt-1">commandes payees</span>
        </div>
      </div>
    </div>

    {# Sponsoring Bonus #}
    <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-purple-50 flex items-center justify-center flex-shrink-0">
          <i data-lucide="gift" class="w-6 h-6 text-purple-600"></i>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-500">Bonus parrainage</p>
          <p class="text-2xl font-bold text-gray-900 mt-0.5">{{ totalSponsoringBonus|number_format(0, ',', '.') }} <span class="text-sm font-semibold text-gray-400">FCFA</span></p>
          <span class="text-xs text-gray-400 mt-1">total distribue</span>
        </div>
      </div>
    </div>
  </div>

  {# Quick Actions #}
  <div>
    <h2 class="text-lg font-bold text-gray-900 mb-3">Actions rapides</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
      <a href="{{ path('user_list_all') }}" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 hover:border-jessica-400 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 group">
        <div class="w-10 h-10 rounded-lg bg-jessica-50 flex items-center justify-center group-hover:bg-jessica-100 transition-colors">
          <i data-lucide="users" class="w-5 h-5 text-jessica-500"></i>
        </div>
        <div>
          <div class="text-sm font-semibold text-gray-800">Gerer les membres</div>
          <div class="text-xs text-gray-400">Voir, activer, modifier</div>
        </div>
      </a>
      <a href="{{ path('user_new_from_known_sponsor') }}" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 hover:border-accent-400 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 group">
        <div class="w-10 h-10 rounded-lg bg-accent-50 flex items-center justify-center group-hover:bg-accent-100 transition-colors">
          <i data-lucide="user-plus" class="w-5 h-5 text-accent-500"></i>
        </div>
        <div>
          <div class="text-sm font-semibold text-gray-800">Ajouter un membre</div>
          <div class="text-xs text-gray-400">Inscription rapide</div>
        </div>
      </a>
      <a href="{{ path('view_recap') }}" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 hover:border-blue-400 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 group">
        <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center group-hover:bg-blue-100 transition-colors">
          <i data-lucide="receipt" class="w-5 h-5 text-blue-600"></i>
        </div>
        <div>
          <div class="text-sm font-semibold text-gray-800">Commissions</div>
          <div class="text-xs text-gray-400">Rapport du cycle</div>
        </div>
      </a>
      <a href="{{ path('close_cycle_list') }}" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 hover:border-purple-400 hover:shadow-md transition-all duration-200 hover:-translate-y-0.5 group">
        <div class="w-10 h-10 rounded-lg bg-purple-50 flex items-center justify-center group-hover:bg-purple-100 transition-colors">
          <i data-lucide="rotate-ccw" class="w-5 h-5 text-purple-600"></i>
        </div>
        <div>
          <div class="text-sm font-semibold text-gray-800">Finaliser un cycle</div>
          <div class="text-xs text-gray-400">Cloture et calculs</div>
        </div>
      </a>
    </div>
  </div>

  {# Two Columns: Recent Activations + Recent Orders #}
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    {# Recent Activations #}
    <div class="bg-white rounded-xl border border-gray-200">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <h3 class="text-sm font-bold text-gray-800">Activations recentes</h3>
        <a href="{{ path('user_list_all') }}" class="text-xs font-semibold text-jessica-500 hover:text-jessica-600 transition-colors">Voir tout</a>
      </div>
      <div class="divide-y divide-gray-50">
        {% for u in recentActivations %}
        <div class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50 transition-colors">
          <div class="w-8 h-8 rounded-full bg-jessica-100 flex items-center justify-center text-xs font-bold text-jessica-600 flex-shrink-0">
            {{ u.fullname|first|upper }}
          </div>
          <div class="min-w-0 flex-1">
            <div class="text-sm font-semibold text-gray-800 truncate">{{ u.fullname }}</div>
            <div class="text-xs text-gray-400">{{ u.membership.name|default('—') }}</div>
          </div>
          <div class="text-xs text-gray-400 flex-shrink-0">
            {% if u.dateActivation %}{{ u.dateActivation|date('d/m/Y') }}{% endif %}
          </div>
        </div>
        {% else %}
        <div class="px-5 py-8 text-center text-sm text-gray-400">
          <i data-lucide="inbox" class="w-8 h-8 mx-auto mb-2 opacity-40"></i>
          <p>Aucune activation recente</p>
        </div>
        {% endfor %}
      </div>
    </div>

    {# Recent Orders #}
    <div class="bg-white rounded-xl border border-gray-200">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <h3 class="text-sm font-bold text-gray-800">Dernieres commandes</h3>
        <a href="{{ path('list_all_user_commands') }}" class="text-xs font-semibold text-jessica-500 hover:text-jessica-600 transition-colors">Voir tout</a>
      </div>
      <div class="divide-y divide-gray-50">
        {% for order in recentOrders %}
        <div class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50 transition-colors">
          <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
            <i data-lucide="package" class="w-4 h-4 text-blue-600"></i>
          </div>
          <div class="min-w-0 flex-1">
            <div class="text-sm font-semibold text-gray-800 truncate">{{ order.user.fullname }}</div>
            <div class="text-xs text-gray-400">#{{ order.code|default(order.id) }}</div>
          </div>
          <div class="text-right flex-shrink-0">
            <div class="text-sm font-bold text-gray-800">{{ order.totalDistributorPrice|number_format(0, ',', '.') }} F</div>
            <div class="text-xs">
              {% if order.paid %}
                <span class="text-jessica-500 font-semibold">Paye</span>
              {% else %}
                <span class="text-amber-500 font-semibold">En attente</span>
              {% endif %}
            </div>
          </div>
        </div>
        {% else %}
        <div class="px-5 py-8 text-center text-sm text-gray-400">
          <i data-lucide="inbox" class="w-8 h-8 mx-auto mb-2 opacity-40"></i>
          <p>Aucune commande recente</p>
        </div>
        {% endfor %}
      </div>
    </div>

  </div>

  {# Network Overview #}
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-bold text-gray-800">Vue d'ensemble du reseau</h3>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="text-center p-4 bg-gray-50 rounded-xl">
        <div class="text-2xl font-bold text-jessica-500">{{ activeMembers }}</div>
        <div class="text-xs text-gray-500 mt-1">Membres actifs</div>
      </div>
      <div class="text-center p-4 bg-gray-50 rounded-xl">
        <div class="text-2xl font-bold text-amber-500">{{ inactiveMembers }}</div>
        <div class="text-xs text-gray-500 mt-1">Membres inactifs</div>
      </div>
      <div class="text-center p-4 bg-gray-50 rounded-xl">
        <div class="text-2xl font-bold text-blue-600">{{ totalOrders }}</div>
        <div class="text-xs text-gray-500 mt-1">Commandes payees</div>
      </div>
      <div class="text-center p-4 bg-gray-50 rounded-xl">
        <div class="text-2xl font-bold text-purple-600">{{ pendingSubscriptions }}</div>
        <div class="text-xs text-gray-500 mt-1">Souscr. en attente</div>
      </div>
    </div>
  </div>

</div>
{% endblock %}
