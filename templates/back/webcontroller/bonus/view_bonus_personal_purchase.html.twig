{% extends 'base.html.twig' %}
{% block title %}Bonus Achat personnel - RACS Health Global{% endblock %}
{% block page_title %}Bonus Achat personnel{% endblock %}
{% block nav_bonus %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">

  {# Period Filter #}
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <form class="flex flex-wrap items-end gap-3">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-500 mb-1">Periode</label>
        {{ form_widget(form.period, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
      </div>
      <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
        <i data-lucide="filter" class="w-4 h-4"></i> Afficher
      </button>
    </form>
  </div>

  {# Purchase Table #}
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm" id="table-info">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Code</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden sm:table-cell">Date Commande</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-600">SV AP</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-600">Cout</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {% for command in userCommands %}
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3">
              <span class="font-mono text-xs bg-gray-100 px-2 py-0.5 rounded">{{ command.code }}</span>
            </td>
            <td class="px-4 py-3 text-gray-600 hidden sm:table-cell">{{ command.dateCommand|date('d/m/Y H:i') }}</td>
            <td class="px-4 py-3 text-right text-gray-800 font-semibold">{{ svPersonalPurchases[command.code] }}</td>
            <td class="px-4 py-3 text-right font-bold text-jessica-500">{{ svCosts[command.code] }}</td>
          </tr>
          {% else %}
          <tr>
            <td colspan="4" class="px-5 py-8 text-center text-sm text-gray-400">
              <i data-lucide="inbox" class="w-8 h-8 mx-auto mb-2 opacity-40"></i>
              <p>Aucun achat au cours de ce cycle</p>
            </td>
          </tr>
          {% endfor %}
        </tbody>
        <tfoot>
          <tr class="bg-gray-50 border-t border-gray-200">
            <td colspan="3" class="px-4 py-3 text-right font-bold text-gray-700">Total</td>
            <td class="px-4 py-3 text-right font-bold text-jessica-600 text-lg">{{ total }}</td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('datatable') }}
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('datatable') }}
{% endblock %}
