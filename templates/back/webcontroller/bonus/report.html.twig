{% extends 'base.html.twig' %}
{% block title %}Commissions du cycle - RACS Health Global{% endblock %}
{% block page_title %}Les commissions du cycle{% endblock %}
{% block nav_bonus %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">

  {# Period Filter #}
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <form class="flex flex-wrap items-end gap-3">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-500 mb-1">Periode</label>
        {{ form_widget(form.period, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
      </div>
      <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
        <i data-lucide="filter" class="w-4 h-4"></i> Afficher
      </button>
    </form>
  </div>

  {# Commission Table #}
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm" id="table-info">
        <thead>
          <tr class="bg-jessica-500 text-white">
            <th colspan="3" class="px-3 py-2 text-left text-xs font-semibold"></th>
            <th colspan="2" class="px-3 py-2 text-center text-xs font-semibold border-l border-jessica-400">ACTIF</th>
            <th colspan="3" class="px-3 py-2 text-center text-xs font-semibold border-l border-jessica-400">PASSIF</th>
            <th class="px-3 py-2 text-center text-xs font-semibold border-l border-jessica-400">TOTAL</th>
          </tr>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-3 py-3 text-left font-semibold text-gray-600 text-xs">N</th>
            <th class="px-3 py-3 text-left font-semibold text-gray-600 text-xs">Noms et Prenoms</th>
            <th class="px-3 py-3 text-left font-semibold text-gray-600 text-xs">Tel.</th>
            <th class="px-3 py-3 text-right font-semibold text-gray-600 text-xs">Parrainage</th>
            <th class="px-3 py-3 text-right font-semibold text-gray-600 text-xs">Achat P.</th>
            <th class="px-3 py-3 text-right font-semibold text-gray-600 text-xs">Binaire</th>
            <th class="px-3 py-3 text-right font-semibold text-gray-600 text-xs">Generationnel</th>
            <th class="px-3 py-3 text-right font-semibold text-gray-600 text-xs">Indirect</th>
            <th class="px-3 py-3 text-right font-semibold text-gray-800 text-xs">Commissions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {% for report in reports %}
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-3 py-2.5 text-gray-400 text-xs">{{ report['id'] }}</td>
            <td class="px-3 py-2.5 font-semibold text-gray-800 text-xs">{{ report['fullname'] }}</td>
            <td class="px-3 py-2.5 text-gray-500 text-xs">{{ report['telephone'] }}</td>
            <td class="px-3 py-2.5 text-right text-xs">{% if report['parrainage'] is defined %}{{ report['parrainage'] }}{% endif %}</td>
            <td class="px-3 py-2.5 text-right text-xs">{% if report['achat_personal'] is defined %}{{ report['achat_personal'] }}{% endif %}</td>
            <td class="px-3 py-2.5 text-right text-xs">{% if report['binaire'] is defined %}{{ report['binaire'] }}{% endif %}</td>
            <td class="px-3 py-2.5 text-right text-xs">{% if report['generationnel'] is defined %}{{ report['generationnel'] }}{% endif %}</td>
            <td class="px-3 py-2.5 text-right text-xs">{% if report['indirect_bonus'] is defined %}{{ report['indirect_bonus'] }}{% endif %}</td>
            <td class="px-3 py-2.5 text-right font-bold text-jessica-500 text-xs">{{ report['commissions'] }}</td>
          </tr>
          {% endfor %}
        </tbody>
        <tfoot>
          <tr class="bg-gray-50 border-t-2 border-gray-300 font-bold text-sm">
            <td colspan="3" class="px-3 py-3 text-right text-gray-700">TOTAL</td>
            <td colspan="2" class="px-3 py-3 text-center text-jessica-600">{{ actif }}</td>
            <td colspan="3" class="px-3 py-3 text-center text-blue-600">{{ passif }}</td>
            <td class="px-3 py-3 text-right text-jessica-600 text-lg">{{ total }}</td>
          </tr>
        </tfoot>
      </table>
    </div>
    <div class="px-5 py-3 border-t border-gray-100">
      <p class="text-xs text-gray-400"><strong>1 VA = 1 SV = 600 FCFA = 1 Dollar US</strong></p>
    </div>
  </div>
</div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('datatable') }}
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('datatable') }}
{% endblock %}
