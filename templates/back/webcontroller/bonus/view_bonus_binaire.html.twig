{% extends 'base.html.twig' %}
{% block title %}Bonus de groupe - RACS Health Global{% endblock %}
{% block page_title %}Bonus de groupe{% endblock %}
{% block nav_bonus %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">

  {# Period Filter #}
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <form class="flex flex-wrap items-end gap-3">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-500 mb-1">Periode</label>
        {{ form_widget(form.period, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
      </div>
      <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
        <i data-lucide="filter" class="w-4 h-4"></i> Afficher
      </button>
    </form>
  </div>

  {# Binary Bonus Table #}
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
      <i data-lucide="git-merge" class="w-5 h-5 text-jessica-500"></i>
      <h3 class="text-sm font-bold text-gray-800">Calcul du bonus binaire</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th colspan="3" class="px-3 py-2 text-center text-xs font-semibold text-jessica-600 border-r border-gray-200">AG (Gauche)</th>
            <th colspan="3" class="px-3 py-2 text-center text-xs font-semibold text-blue-600 border-r border-gray-200">AD (Droite)</th>
            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-600">ACO</th>
            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-600">{% if side == 'left' %}AG{% else %}AD{% endif %}+ACO</th>
            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-600">NCO</th>
            <th class="px-3 py-2 text-center text-xs font-semibold text-gray-600">Bin</th>
            <th class="px-3 py-2 text-center text-xs font-semibold text-jessica-600">Gain</th>
          </tr>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-3 py-2 text-center text-xs text-gray-500">P</th>
            <th class="px-3 py-2 text-center text-xs text-gray-500">AC</th>
            <th class="px-3 py-2 text-center text-xs text-gray-500 border-r border-gray-200">TAG</th>
            <th class="px-3 py-2 text-center text-xs text-gray-500">P</th>
            <th class="px-3 py-2 text-center text-xs text-gray-500">AC</th>
            <th class="px-3 py-2 text-center text-xs text-gray-500 border-r border-gray-200">TAD</th>
            <th colspan="5"></th>
          </tr>
        </thead>
        <tbody>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-3 text-center">{{ results['pl'] }}</td>
            <td class="px-3 py-3 text-center">{{ results['al'] }}</td>
            <td class="px-3 py-3 text-center font-semibold border-r border-gray-200">{{ results['tl'] }}</td>
            <td class="px-3 py-3 text-center">{{ results['pr'] }}</td>
            <td class="px-3 py-3 text-center">{{ results['ar'] }}</td>
            <td class="px-3 py-3 text-center font-semibold border-r border-gray-200">{{ results['tr'] }}</td>
            <td class="px-3 py-3 text-center">{{ results['a_co'] }}</td>
            <td class="px-3 py-3 text-center">{{ results['bm'] }}</td>
            <td class="px-3 py-3 text-center">{{ results['n_co'] }}</td>
            <td class="px-3 py-3 text-center font-semibold">{{ results['binaire'] }}</td>
            <td class="px-3 py-3 text-center font-bold text-jessica-500 text-lg">{{ results['gain'] }}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  {# Legend #}
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
      <i data-lucide="info" class="w-5 h-5 text-gray-400"></i>
      <h3 class="text-sm font-bold text-gray-800">Legende</h3>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-0 divide-x divide-y divide-gray-100">
      <div class="px-4 py-3"><span class="text-xs font-bold text-jessica-500">AG</span> <span class="text-xs text-gray-500">Activite Gauche</span></div>
      <div class="px-4 py-3"><span class="text-xs font-bold text-blue-600">AD</span> <span class="text-xs text-gray-500">Activite Droite</span></div>
      <div class="px-4 py-3"><span class="text-xs font-bold text-gray-700">ACO</span> <span class="text-xs text-gray-500">Ancien Carry Over</span></div>
      <div class="px-4 py-3"><span class="text-xs font-bold text-gray-700">NCO</span> <span class="text-xs text-gray-500">Nouveau Carry Over</span></div>
      <div class="px-4 py-3"><span class="text-xs font-bold text-gray-700">Bin</span> <span class="text-xs text-gray-500">Binaire</span></div>
      <div class="px-4 py-3"><span class="text-xs font-bold text-gray-700">P</span> <span class="text-xs text-gray-500">Parrainage</span></div>
      <div class="px-4 py-3"><span class="text-xs font-bold text-gray-700">AC</span> <span class="text-xs text-gray-500">Achat</span></div>
      <div class="px-4 py-3"><span class="text-xs font-bold text-jessica-500">TAG</span> <span class="text-xs text-gray-500">Total Activite Gauche</span></div>
      <div class="px-4 py-3"><span class="text-xs font-bold text-blue-600">TAD</span> <span class="text-xs text-gray-500">Total Activite Droite</span></div>
    </div>
  </div>
</div>
{% endblock %}
