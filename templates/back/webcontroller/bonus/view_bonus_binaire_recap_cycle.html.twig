{% extends 'base.html.twig' %}
{% block title %}Bonus Binaire du Cycle - RACS Health Global{% endblock %}
{% block page_title %}Bonus Binaire du Cycle{% endblock %}
{% block nav_bonus %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">

  {# Period Filter #}
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <form class="flex flex-wrap items-end gap-3">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-500 mb-1">Periode</label>
        {{ form_widget(form.period, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
      </div>
      <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
        <i data-lucide="filter" class="w-4 h-4"></i> Afficher
      </button>
    </form>
  </div>

  {# Pay Button #}
  {% if closed and not paid %}
  <div class="flex items-center gap-3">
    <button class="inline-flex items-center gap-2 px-4 py-2.5 bg-accent-500 text-white text-sm font-semibold rounded-lg hover:bg-accent-600 transition-colors shadow-sm" type="button" name="paid" id="paid">
      <i data-lucide="check-circle" class="w-4 h-4"></i> Marquer comme paye
    </button>
  </div>
  {% endif %}

  {# Bonus Table #}
  <div id="content-panel" class="bg-white rounded-xl border border-gray-200 overflow-hidden" data-url="{{ app.request.attributes.get('_route') }}">
    <section id="adv-table" data-message="Binaire" data-month="{{ month }}" data-year="{{ year }}" data-startedAt="{{ startedAt }}" data-endedAt="{{ endedAt }}">
      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="table-info">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              {% if closed and not paid %}
              <th class="px-4 py-3 text-left">
                <input type="checkbox" id="check_all" class="rounded border-gray-300 text-jessica-500 focus:ring-jessica-500">
              </th>
              {% endif %}
              <th class="px-4 py-3 text-left font-semibold text-gray-600">Beneficiaire</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-600">Montant</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-600">SV Gain</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-600">CO</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-600">Statut</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {% for bonus_binaire_cycle in bonus_binaire_cycles %}
            <tr class="hover:bg-gray-50 transition-colors">
              {% if closed and not paid %}
              <td class="px-4 py-3">
                {% if not bonus_binaire_cycle.status %}
                <input type="checkbox" class="check_item rounded border-gray-300 text-jessica-500 focus:ring-jessica-500" value="{{ bonus_binaire_cycle.user.id }}">
                {% endif %}
              </td>
              {% endif %}
              <td class="px-4 py-3 font-semibold text-gray-800">{{ bonus_binaire_cycle.user.fullname }}</td>
              <td class="px-4 py-3 text-right font-bold text-jessica-500">{{ bonus_binaire_cycle['gain'] }}</td>
              <td class="px-4 py-3 text-right text-gray-600">{{ bonus_binaire_cycle['binaire'] }}</td>
              <td class="px-4 py-3 text-right text-gray-600">{{ bonus_binaire_cycle['n_co'] }}</td>
              <td class="px-4 py-3 text-center">
                {% if bonus_binaire_cycle.status %}
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-600">
                    <i data-lucide="check" class="w-3 h-3"></i> Paye
                  </span>
                {% else %}
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-50 text-amber-600">
                    <i data-lucide="clock" class="w-3 h-3"></i> En attente
                  </span>
                {% endif %}
              </td>
            </tr>
            {% else %}
            <tr>
              <td colspan="{% if closed and not paid %}6{% else %}5{% endif %}" class="px-5 py-8 text-center text-sm text-gray-400">
                <i data-lucide="inbox" class="w-8 h-8 mx-auto mb-2 opacity-40"></i>
                <p>Aucun bonus binaire pour ce cycle</p>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('paid_bonus_ap') }}
{% endblock %}
