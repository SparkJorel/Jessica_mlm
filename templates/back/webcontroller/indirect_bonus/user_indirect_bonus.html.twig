{% extends 'base.html.twig' %}
{% block title %}Indirect Bonus - RACS Health Global{% endblock %}
{% block page_title %}Indirect Bonus : Consulter{% endblock %}
{% block nav_bonus %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">

  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <form class="flex flex-wrap items-end gap-3">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-500 mb-1">Periode</label>
        {{ form_widget(form.period, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
      </div>
      <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
        <i data-lucide="filter" class="w-4 h-4"></i> Afficher
      </button>
    </form>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Niveau</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-600">SV Achat</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-600">Cout Achat</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-600">Parrainage</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-600">Total</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {% for key, result in results %}
            {% if result is iterable %}
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-purple-50 text-purple-600">Niv. {{ key }}</span>
              </td>
              <td class="px-4 py-3 text-right text-gray-600">{% if result['purchase_sv'] is defined %}{{ result['purchase_sv'] }}{% endif %}</td>
              <td class="px-4 py-3 text-right text-gray-600">{% if result['purchase_price'] is defined %}{{ result['purchase_price'] }}{% endif %}</td>
              <td class="px-4 py-3 text-right text-gray-600">{% if result['subscription_price'] is defined %}{{ result['subscription_price'] }}{% endif %}</td>
              <td class="px-4 py-3 text-right font-bold text-jessica-500">{% if result['total_level'] is defined %}{{ result['total_level'] }}{% endif %}</td>
            </tr>
            {% endif %}
          {% else %}
          <tr>
            <td colspan="5" class="px-5 py-8 text-center text-sm text-gray-400">
              <i data-lucide="inbox" class="w-8 h-8 mx-auto mb-2 opacity-40"></i>
              <p>Aucun bonus pour l'instant</p>
            </td>
          </tr>
          {% endfor %}
        </tbody>
        {% if results is defined and results is not null %}
        <tfoot>
          <tr class="bg-gray-50 border-t border-gray-200">
            <td colspan="4" class="px-4 py-3 text-right font-bold text-gray-700">Total</td>
            <td class="px-4 py-3 text-right font-bold text-jessica-600 text-lg">{{ results['total_indirect_bonus'] }}</td>
          </tr>
        </tfoot>
        {% endif %}
      </table>
    </div>
  </div>
</div>
{% endblock %}
