{% extends 'base.html.twig' %}
{% block title %}Paiement confirme - RACS Health Global{% endblock %}
{% block page_title %}Confirmation du paiement{% endblock %}

{% block main %}
<div class="max-w-lg mx-auto -m-5 sm:-m-6">
  <div class="bg-white rounded-xl border border-gray-200 p-8 text-center">
    <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
      <i data-lucide="check-circle-2" class="w-8 h-8 text-green-500"></i>
    </div>
    <h2 class="text-xl font-bold text-gray-800 mb-2">Paiement reussi !</h2>
    <p class="text-sm text-gray-500 mb-6">{{ message }}</p>
    <a href="{{ path('user_command_list') }}" class="inline-flex items-center gap-2 px-5 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
      <i data-lucide="list" class="w-4 h-4"></i> Consulter vos achats
    </a>
  </div>
</div>
{% endblock %}
