{% extends 'base.html.twig' %}
{% block title %}Confirmation du paiement - RACS Health Global{% endblock %}
{% block page_title %}
Valider le processus de paiement initie avec {% if operateur == 1 %}
  MTN Mobile Money
{% elseif operateur == 2 %}
  Orange Money
{% else %}
  Express Union Mobile
{% endif %}
{% endblock %}
{% block main %}
<div class="space-y-6 -m-5 sm:-m-6">
  <!-- SMS Code Form -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="border-b border-gray-200 bg-gray-50 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-800">Code de confirmation</h2>
    </div>
    <div class="p-6">
      {{ form_start(form) }}
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.rcs.vars.label }}</label>
          {{ form_errors(form.rcs) }}
          {{ form_widget(form.rcs, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-jessica-500 focus:ring-1 focus:ring-jessica-500'}}) }}
          <p class="mt-1.5 text-xs text-gray-500">Veuillez saisir le code recu par SMS sur votre telephone portable</p>
        </div>
        <div class="flex justify-end">
          <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-accent-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-accent-600 transition"><i data-lucide="check-circle" class="w-4 h-4"></i>Valider le paiement</button>
        </div>
      </div>
      {{ form_end(form) }}
    </div>
  </div>

  <!-- Cart Summary -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="border-b border-gray-200 bg-gray-50 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-800">Recapitulatif</h2>
    </div>
    <ul class="divide-y divide-gray-100">
      {% for cp in cart.products %}
      <li class="px-6 py-3 flex items-center justify-between">
        <span class="text-sm text-gray-700">{{ cp.product.name }} <span class="text-gray-400">(FCFA {{ cp.product.distributorPrice }})</span></span>
        <span class="inline-flex items-center rounded-full bg-jessica-50 px-2.5 py-0.5 text-xs font-medium text-jessica-700 ring-1 ring-inset ring-jessica-600/20">{{ cp.quantity }}</span>
      </li>
      {% endfor %}
    </ul>
    <div class="border-t border-gray-200 bg-gray-50 px-6 py-4 flex items-center justify-between">
      <span class="text-sm font-semibold text-gray-900">Total</span>
      <span class="text-sm font-bold text-gray-900">{{ cart.totalDistributorWithoutShippingCost }} FCFA</span>
    </div>
  </div>
</div>
{% endblock %}
