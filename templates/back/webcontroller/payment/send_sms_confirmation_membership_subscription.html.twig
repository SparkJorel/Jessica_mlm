{% extends 'base.html.twig' %}
{% block title %}Confirmation du paiement - RACS Health Global{% endblock %}
{% block page_title %}
Valider le processus de paiement initie avec {% if operateur == 1 %}
  MTN Mobile Money
{% elseif operateur == 2 %}
  Orange Money
{% else %}
  Express Union Mobile
{% endif %}
{% endblock %}
{% block main %}
<div class="space-y-6 -m-5 sm:-m-6">
  <!-- SMS Code Form -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="border-b border-gray-200 bg-gray-50 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-800">Code de confirmation</h2>
    </div>
    <div class="p-6">
      {{ form_start(form) }}
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.rcs.vars.label }}</label>
          {{ form_errors(form.rcs) }}
          {{ form_widget(form.rcs, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-jessica-500 focus:ring-1 focus:ring-jessica-500'}}) }}
          <p class="mt-1.5 text-xs text-gray-500">Veuillez saisir le code recu par SMS sur votre telephone portable</p>
        </div>
        <div class="flex justify-end">
          <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-accent-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-accent-600 transition"><i data-lucide="check-circle" class="w-4 h-4"></i>Valider le paiement</button>
        </div>
      </div>
      {{ form_end(form) }}
    </div>
  </div>

  <!-- Subscription Summary Table -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="border-b border-gray-200 bg-gray-50 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-800">Les packs commandes</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 font-semibold text-gray-700">Pack de souscription</th>
            <th class="px-4 py-3 font-semibold text-gray-700">Quantite</th>
            <th class="px-4 py-3 font-semibold text-gray-700">Prix</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {% for packName, summary in summaries %}
          <tr class="hover:bg-gray-50 transition">
            <td class="px-4 py-3 text-gray-800 font-medium">{{ packName }}</td>
            <td class="px-4 py-3 text-gray-600">{{ summary['quantity'] }}</td>
            <td class="px-4 py-3 text-gray-600">{{ summary['price'] }}</td>
          </tr>
          {% endfor %}
        </tbody>
        <tfoot>
          <tr class="bg-gray-50 border-t border-gray-200">
            <td colspan="2" class="px-4 py-3 text-sm font-semibold text-gray-900">Total</td>
            <td class="px-4 py-3 text-sm font-bold text-gray-900">{{ total }}</td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>
{% endblock %}
