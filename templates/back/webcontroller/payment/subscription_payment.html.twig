{% extends 'base.html.twig' %}
{% block title %}Paiement - RACS Health Global{% endblock %}
{% block page_title %}Payer sa facture avec {% if operateur == 1 %}MTN Mobile Money{% elseif operateur == 2 %}Orange Money{% elseif operateur == 3 %}Express Union Mobile{% endif %}{% endblock %}

{% block main %}
<div class="max-w-3xl mx-auto -m-5 sm:-m-6">
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

    {# Payment Form #}
    <div class="lg:col-span-3">
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-jessica-50 flex items-center justify-center">
            {% if operateur == 1 %}
              <img src="{{ asset('img/MTN-Mobile-Money.png') }}" alt="MTN" class="w-6 h-6 object-contain">
            {% elseif operateur == 2 %}
              <img src="{{ asset('img/orange-money.jpg') }}" alt="Orange" class="w-6 h-6 object-contain">
            {% else %}
              <img src="{{ asset('img/logoeu.jpg') }}" alt="EU" class="w-6 h-6 object-contain">
            {% endif %}
          </div>
          <div>
            <h2 class="text-sm font-bold text-gray-800">Paiement mobile</h2>
            <p class="text-xs text-gray-400">Entrez vos informations de paiement</p>
          </div>
        </div>
        <div class="p-6">
          {{ form_start(form) }}
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.telephone.vars.label }}</label>
              {{ form_widget(form.telephone, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition' ~ (form.telephone.vars.valid ? '' : ' border-red-400 bg-red-50')}}) }}
              {{ form_help(form.telephone) }}
              {% if not form.telephone.vars.valid %}<p class="text-xs text-red-500 mt-1">{{ form_errors(form.telephone) }}</p>{% endif %}
            </div>
            {% if form.otpCode is defined %}
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{{ form.otpCode.vars.label }}</label>
              {{ form_widget(form.otpCode, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
              <p class="text-xs text-gray-400 mt-1">Composez <strong class="text-jessica-500">#150*4*4#</strong> pour obtenir votre code OTP</p>
            </div>
            {% endif %}
            <div class="flex gap-3 pt-2">
              <a href="{{ path('summary_subscription_cart') }}" class="inline-flex items-center gap-2 px-4 py-2.5 bg-gray-100 text-gray-700 text-sm font-semibold rounded-lg hover:bg-gray-200 transition-colors">
                <i data-lucide="arrow-left" class="w-4 h-4"></i> Retour
              </a>
              <button type="submit" class="flex-1 inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors shadow-sm">
                <i data-lucide="credit-card" class="w-4 h-4"></i> Payer
              </button>
            </div>
          </div>
          {{ form_end(form) }}
        </div>
      </div>
    </div>

    {# Order Summary #}
    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden sticky top-24">
        <div class="px-5 py-4 border-b border-gray-100">
          <h3 class="text-sm font-bold text-gray-800 flex items-center gap-2">
            <i data-lucide="receipt" class="w-4 h-4 text-jessica-500"></i>
            Packs commandes
          </h3>
        </div>
        <div class="divide-y divide-gray-100">
          {% for packName, summary in summaries %}
          <div class="flex items-center justify-between px-5 py-3">
            <div>
              <div class="text-sm font-semibold text-gray-800">{{ packName }}</div>
              <div class="text-xs text-gray-400">x{{ summary['quantity'] }}</div>
            </div>
            <span class="text-sm font-bold text-gray-800">{{ summary['price']|number_format(0, ',', '.') }}</span>
          </div>
          {% endfor %}
        </div>
        <div class="px-5 py-4 bg-gray-50 border-t border-gray-200">
          <div class="flex items-center justify-between">
            <span class="text-sm font-bold text-gray-800">Total</span>
            <span class="text-lg font-bold text-jessica-500">{{ total|number_format(0, ',', '.') }} <span class="text-xs text-gray-400">FCFA</span></span>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
{% endblock %}
