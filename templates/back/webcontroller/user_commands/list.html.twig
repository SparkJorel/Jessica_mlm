{% extends 'base.html.twig' %}
{% block title %}{{ title }} - RACS Health Global{% endblock %}
{% block page_title %}{{ title }}{% endblock %}
{% block nav_orders %}bg-jessica-500 text-white{% endblock %}

{% block main %}
<div class="space-y-5 -m-5 sm:-m-6">

  {# Period Filter #}
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <form id="cycle-filter-form" class="flex flex-wrap items-end gap-3">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-500 mb-1">Periode</label>
        {{ form_widget(form.period, {'attr': {'class': 'w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-jessica-500 focus:ring-2 focus:ring-jessica-500/20 focus:outline-none transition'}}) }}
      </div>
      <div id="cycle-loader" class="hidden">
        <svg class="animate-spin w-5 h-5 text-jessica-500" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
      </div>
      <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors">
        <i data-lucide="filter" class="w-4 h-4"></i> Afficher
      </button>
    </form>
  </div>

  {# Action Bar #}
  <div class="flex items-center gap-3">
    <a href="{{ path('products_all') }}" class="inline-flex items-center gap-2 px-4 py-2.5 bg-jessica-500 text-white text-sm font-semibold rounded-lg hover:bg-jessica-600 transition-colors shadow-sm">
      <i data-lucide="shopping-bag" class="w-4 h-4"></i>
      Commander
    </a>
  </div>

  {# Orders Table #}
  <div id="orders-table-container" class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Nom & Prenoms</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden sm:table-cell">Code</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600 hidden md:table-cell">Date Commande</th>
            <th class="px-4 py-3 text-center font-semibold text-gray-600">Paye</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-600 hidden lg:table-cell">SV</th>
            <th class="px-4 py-3 text-right font-semibold text-gray-600 hidden lg:table-cell">SV AP</th>
            {% if is_granted('ROLE_JTWC_ADMIN') or is_granted('ROLE_JTWC_USER_SECRET') %}
            <th class="px-4 py-3 text-center font-semibold text-gray-600">Actions</th>
            {% endif %}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {% for command in userCommands %}
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3">
              <div class="font-semibold text-gray-800">{{ command.user.fullname }}</div>
              <div class="text-xs text-gray-400 sm:hidden">{{ command.code }}</div>
            </td>
            <td class="px-4 py-3 text-gray-600 hidden sm:table-cell">
              <span class="font-mono text-xs bg-gray-100 px-2 py-0.5 rounded">{{ command.code }}</span>
            </td>
            <td class="px-4 py-3 text-gray-600 hidden md:table-cell">{{ command.dateCommand|date('d/m/Y H:i') }}</td>
            <td class="px-4 py-3 text-center">
              {% if command.paid %}
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-600">
                  <i data-lucide="check" class="w-3 h-3"></i> Oui
                </span>
              {% else %}
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-50 text-amber-600">
                  <i data-lucide="clock" class="w-3 h-3"></i> Non
                </span>
              {% endif %}
            </td>
            <td class="px-4 py-3 text-right text-gray-600 hidden lg:table-cell">{% if command.totalSVBinaire is not null %}{{ command.totalSVBinaire }}{% else %}{{ svUserCommands[command.code] }}{% endif %}</td>
            <td class="px-4 py-3 text-right text-gray-600 hidden lg:table-cell">{% if command.totalSVAP is not null %}{{ command.totalSVAP }}{% else %}{{ svAchatUserCommands[command.code] }}{% endif %}</td>
            {% if is_granted('ROLE_JTWC_ADMIN') or is_granted('ROLE_JTWC_USER_SECRET') %}
            <td class="px-4 py-3">
              <div class="flex items-center justify-center gap-1">
                <a href="{{ path('user_command_edit', {'id': command.id}) }}" title="Modifier" class="p-1.5 rounded-lg text-blue-600 hover:bg-blue-50 transition-colors">
                  <i data-lucide="pencil" class="w-4 h-4"></i>
                </a>
                {% if not command.delivered %}
                  <button type="button" title="Livrer" class="p-1.5 rounded-lg text-purple-600 hover:bg-purple-50 transition-colors" onclick="openModal('deliver-{{ command.id }}')">
                    <i data-lucide="truck" class="w-4 h-4"></i>
                  </button>
                {% else %}
                  <span class="p-1.5 text-green-500" title="Livre"><i data-lucide="package-check" class="w-4 h-4"></i></span>
                {% endif %}
                {% if not command.paid %}
                  <button type="button" title="Payer" class="p-1.5 rounded-lg text-accent-500 hover:bg-accent-50 transition-colors" onclick="openModal('pay-{{ command.id }}')">
                    <i data-lucide="credit-card" class="w-4 h-4"></i>
                  </button>
                {% else %}
                  <span class="p-1.5 text-green-500" title="Paye"><i data-lucide="badge-check" class="w-4 h-4"></i></span>
                {% endif %}
                <button type="button" title="Supprimer" class="p-1.5 rounded-lg text-red-500 hover:bg-red-50 transition-colors" onclick="openModal('delcmd-{{ command.id }}')">
                  <i data-lucide="trash-2" class="w-4 h-4"></i>
                </button>
              </div>

              {# Deliver Modal #}
              {% if not command.delivered %}
              <div id="modal-deliver-{{ command.id }}" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
                <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full mx-4 p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center"><i data-lucide="truck" class="w-5 h-5 text-purple-600"></i></div>
                    <h3 class="text-lg font-bold text-gray-800">Confirmer la livraison ?</h3>
                  </div>
                  <p class="text-sm text-gray-500 mb-6">Voulez-vous confirmer la livraison de cette commande ?</p>
                  <div class="flex gap-3 justify-end">
                    <button onclick="closeModal('deliver-{{ command.id }}')" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Annuler</button>
                    <a href="{{ path('user_command_delivered', {'id': command.id}) }}" class="px-4 py-2 text-sm font-semibold text-white bg-purple-600 rounded-lg hover:bg-purple-700 transition-colors">Confirmer</a>
                  </div>
                </div>
              </div>
              {% endif %}

              {# Pay Modal #}
              {% if not command.paid %}
              <div id="modal-pay-{{ command.id }}" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
                <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full mx-4 p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-full bg-accent-100 flex items-center justify-center"><i data-lucide="credit-card" class="w-5 h-5 text-accent-600"></i></div>
                    <h3 class="text-lg font-bold text-gray-800">Confirmer le paiement ?</h3>
                  </div>
                  <p class="text-sm text-gray-500 mb-6">Voulez-vous confirmer le paiement de cette commande ?</p>
                  <div class="flex gap-3 justify-end">
                    <button onclick="closeModal('pay-{{ command.id }}')" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Annuler</button>
                    <a href="{{ path('user_command_paid', {'id': command.id}) }}" class="px-4 py-2 text-sm font-semibold text-white bg-jessica-500 rounded-lg hover:bg-jessica-600 transition-colors">Confirmer</a>
                  </div>
                </div>
              </div>
              {% endif %}

              {# Delete Modal #}
              <div id="modal-delcmd-{{ command.id }}" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
                <div class="bg-white rounded-2xl shadow-xl max-w-sm w-full mx-4 p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center"><i data-lucide="alert-triangle" class="w-5 h-5 text-red-600"></i></div>
                    <h3 class="text-lg font-bold text-gray-800">Supprimer cette commande ?</h3>
                  </div>
                  <p class="text-sm text-gray-500 mb-6">Cette action est irreversible.</p>
                  <div class="flex gap-3 justify-end">
                    <button onclick="closeModal('delcmd-{{ command.id }}')" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Annuler</button>
                    <form action="{{ path('user_command_delete', {'id': command.id}) }}" method="post" class="inline">
                      <input type="hidden" name="_method" value="DELETE">
                      <input type="hidden" name="_jtwc_user_commands_token" value="{{ csrf_token('jtwc_user_commands-delete'~command.id) }}">
                      <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-red-500 rounded-lg hover:bg-red-600 transition-colors">Supprimer</button>
                    </form>
                  </div>
                </div>
              </div>
            </td>
            {% endif %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
function openModal(id) { const m = document.getElementById('modal-' + id); if (m) { m.classList.remove('hidden'); m.classList.add('flex'); } }
function closeModal(id) { const m = document.getElementById('modal-' + id); if (m) { m.classList.add('hidden'); m.classList.remove('flex'); } }

(function() {
  var select = document.getElementById('period');
  var loader = document.getElementById('cycle-loader');
  var container = document.getElementById('orders-table-container');
  var form = document.getElementById('cycle-filter-form');

  if (!select || !container) return;

  function loadCycle() {
    var period = select.value;
    if (!period) return;

    loader.classList.remove('hidden');
    container.style.opacity = '0.5';
    container.style.transition = 'opacity 0.2s';

    var url = window.location.pathname + '?period=' + encodeURIComponent(period);

    fetch(url)
      .then(function(r) { return r.text(); })
      .then(function(html) {
        var parser = new DOMParser();
        var doc = parser.parseFromString(html, 'text/html');
        var newContainer = doc.getElementById('orders-table-container');

        if (newContainer) {
          container.innerHTML = newContainer.innerHTML;
        }

        history.replaceState(null, '', url);

        if (typeof lucide !== 'undefined') { lucide.createIcons(); }
      })
      .catch(function() {
        window.location.href = url;
      })
      .finally(function() {
        loader.classList.add('hidden');
        container.style.opacity = '1';
      });
  }

  select.addEventListener('change', loadCycle);

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    loadCycle();
  });
})();
</script>
{% endblock %}
